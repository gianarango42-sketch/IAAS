---
import { Picture } from 'astro:assets';
import civilConstruction from '../assets/Obra_civil_en_202603190949.png';
import realEstateDev from '../assets/Proyecto_de_vivienda__202603190949.png';
import consorcios from '../assets/No_tantas_maquinarias._202603190949.png';
---

<!-- SECTION 7: EJECUCIÓN DE OBRAS Y DESARROLLO INMOBILIARIO -->
<section id='obras' class='relative bg-white overflow-hidden'>
  <div class='max-w-7xl mx-auto px-6 sm:px-8 lg:px-12 py-12 sm:py-16 lg:py-20'>
    <!-- Header -->
    <div class='flex items-start justify-between mb-8 sm:mb-10'>
      <div class='max-w-xl'>
        <h2
          class='text-2xl sm:text-3xl lg:text-[2.6rem] font-bold leading-tight text-gray-900 mb-4'
        >
          Ejecución de Obras y
          <span class='text-iaas-blue block'>DESARROLLO INMOBILIARIO</span>
        </h2>
        <p class='text-sm text-iaas-gray leading-relaxed'>
          Capacidad operativa para materializar proyectos de gran envergadura.
        </p>
      </div>
    </div>

    <!-- 3 Cards -->
    <div class='grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 mb-10'>
      <!-- Card 1: Construcción Civil -->
      <div
        class='bg-white rounded-2xl overflow-hidden shadow-md hover:shadow-lg transition-shadow border border-gray-100'
      >
        <!-- Card Image -->
        <div class='relative h-40 sm:h-44 overflow-hidden'>
          <Picture
            src={civilConstruction}
            formats={['avif', 'webp']}
            alt='Proyecto de construcción civil'
            class='w-full h-full object-cover'
            widths={[300, 600]}
            sizes='(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw'
            quality={80}
            loading='lazy'
          />
          <div
            class='absolute inset-0 bg-linear-to-t from-iaas-dark/40 to-transparent'
          >
          </div>
          <!-- Icon -->
          <div
            class='absolute bottom-3 left-4 w-10 h-10 rounded-xl bg-white/90 backdrop-blur-sm flex items-center justify-center shadow'
          >
            <svg
              class='w-5 h-5 text-iaas-blue'
              fill='none'
              viewBox='0 0 24 24'
              stroke='currentColor'
              stroke-width='2'
            >
              <path
                stroke-linecap='round'
                stroke-linejoin='round'
                d='M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4'
              ></path>
            </svg>
          </div>
        </div>
        <!-- Card Content -->
        <div class='p-5'>
          <h3 class='text-sm font-bold text-gray-900 mb-3'>
            Construcción Civil
          </h3>
          <ul class='space-y-2 text-[12px] text-iaas-gray'>
            <li class='flex items-start gap-2'>
              <svg
                class='w-3.5 h-3.5 text-iaas-blue shrink-0 mt-0.5'
                fill='none'
                viewBox='0 0 24 24'
                stroke='currentColor'
                stroke-width='2'
                ><path
                  stroke-linecap='round'
                  stroke-linejoin='round'
                  d='M5 13l4 4L19 7'></path></svg
              >
              Ejecución de obras civiles
            </li>
            <li class='flex items-start gap-2'>
              <svg
                class='w-3.5 h-3.5 text-iaas-blue shrink-0 mt-0.5'
                fill='none'
                viewBox='0 0 24 24'
                stroke='currentColor'
                stroke-width='2'
                ><path
                  stroke-linecap='round'
                  stroke-linejoin='round'
                  d='M5 13l4 4L19 7'></path></svg
              >
              Remodelaciones y mantenimiento
            </li>
            <li class='flex items-start gap-2'>
              <svg
                class='w-3.5 h-3.5 text-iaas-blue shrink-0 mt-0.5'
                fill='none'
                viewBox='0 0 24 24'
                stroke='currentColor'
                stroke-width='2'
                ><path
                  stroke-linecap='round'
                  stroke-linejoin='round'
                  d='M5 13l4 4L19 7'></path></svg
              >
              Vivienda de interés social (Techo Propio, Mivivienda)
            </li>
          </ul>
        </div>
      </div>

      <!-- Card 2: Desarrollo Inmobiliario -->
      <div
        class='bg-white rounded-2xl overflow-hidden shadow-md hover:shadow-lg transition-shadow border border-gray-100'
      >
        <!-- Card Image -->
        <div class='relative h-40 sm:h-44 overflow-hidden'>
          <Picture
            src={realEstateDev}
            formats={['avif', 'webp']}
            alt='Proyecto de desarrollo inmobiliario'
            class='w-full h-full object-cover'
            widths={[300, 600]}
            sizes='(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw'
            quality={80}
            loading='lazy'
          />
          <div
            class='absolute inset-0 bg-linear-to-t from-iaas-dark/40 to-transparent'
          >
          </div>
          <!-- Icon -->
          <div
            class='absolute bottom-3 left-4 w-10 h-10 rounded-xl bg-white/90 backdrop-blur-sm flex items-center justify-center shadow'
          >
            <svg
              class='w-5 h-5 text-iaas-blue'
              fill='none'
              viewBox='0 0 24 24'
              stroke='currentColor'
              stroke-width='2'
            >
              <path
                stroke-linecap='round'
                stroke-linejoin='round'
                d='M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6'
              ></path>
            </svg>
          </div>
        </div>
        <!-- Card Content -->
        <div class='p-5'>
          <h3 class='text-sm font-bold text-gray-900 mb-3'>
            Desarrollo Inmobiliario
          </h3>
          <ul class='space-y-2 text-[12px] text-iaas-gray'>
            <li class='flex items-start gap-2'>
              <svg
                class='w-3.5 h-3.5 text-iaas-blue shrink-0 mt-0.5'
                fill='none'
                viewBox='0 0 24 24'
                stroke='currentColor'
                stroke-width='2'
                ><path
                  stroke-linecap='round'
                  stroke-linejoin='round'
                  d='M5 13l4 4L19 7'></path></svg
              >
              Desarrollo de proyectos inmobiliarios
            </li>
            <li class='flex items-start gap-2'>
              <svg
                class='w-3.5 h-3.5 text-iaas-blue shrink-0 mt-0.5'
                fill='none'
                viewBox='0 0 24 24'
                stroke='currentColor'
                stroke-width='2'
                ><path
                  stroke-linecap='round'
                  stroke-linejoin='round'
                  d='M5 13l4 4L19 7'></path></svg
              >
              Participación en consorcios y asociaciones estratégicas
            </li>
            <li class='flex items-start gap-2'>
              <svg
                class='w-3.5 h-3.5 text-iaas-blue shrink-0 mt-0.5'
                fill='none'
                viewBox='0 0 24 24'
                stroke='currentColor'
                stroke-width='2'
                ><path
                  stroke-linecap='round'
                  stroke-linejoin='round'
                  d='M5 13l4 4L19 7'></path></svg
              >
              Gestión y promoción inmobiliaria
            </li>
          </ul>
        </div>
      </div>

      <!-- Card 3: Consorcios y Asociaciones -->
      <div
        class='bg-white rounded-2xl overflow-hidden shadow-md hover:shadow-lg transition-shadow border border-gray-100 sm:col-span-2 lg:col-span-1'
      >
        <!-- Card Image -->
        <div class='relative h-40 sm:h-44 overflow-hidden'>
          <Picture
            src={consorcios}
            formats={['avif', 'webp']}
            alt='Maquinaria y equipos para proyectos de construcción'
            class='w-full h-full object-cover'
            widths={[300, 600]}
            sizes='(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw'
            quality={80}
            loading='lazy'
          />
          <div
            class='absolute inset-0 bg-linear-to-t from-iaas-dark/40 to-transparent'
          >
          </div>
          <!-- Icon -->
          <div
            class='absolute bottom-3 left-4 w-10 h-10 rounded-xl bg-white/90 backdrop-blur-sm flex items-center justify-center shadow'
          >
            <svg
              class='w-5 h-5 text-iaas-blue'
              fill='none'
              viewBox='0 0 24 24'
              stroke='currentColor'
              stroke-width='2'
            >
              <path
                stroke-linecap='round'
                stroke-linejoin='round'
                d='M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z'
              ></path>
            </svg>
          </div>
        </div>
        <!-- Card Content -->
        <div class='p-5'>
          <h3 class='text-sm font-bold text-gray-900 mb-3'>
            Consorcios y Asociaciones
          </h3>
          <ul class='space-y-2 text-[12px] text-iaas-gray'>
            <li class='flex items-start gap-2'>
              <svg
                class='w-3.5 h-3.5 text-iaas-blue shrink-0 mt-0.5'
                fill='none'
                viewBox='0 0 24 24'
                stroke='currentColor'
                stroke-width='2'
                ><path
                  stroke-linecap='round'
                  stroke-linejoin='round'
                  d='M5 13l4 4L19 7'></path></svg
              >
              Participación en consorcios
            </li>
            <li class='flex items-start gap-2'>
              <svg
                class='w-3.5 h-3.5 text-iaas-blue shrink-0 mt-0.5'
                fill='none'
                viewBox='0 0 24 24'
                stroke='currentColor'
                stroke-width='2'
                ><path
                  stroke-linecap='round'
                  stroke-linejoin='round'
                  d='M5 13l4 4L19 7'></path></svg
              >
              Asociaciones estratégicas
            </li>
          </ul>
        </div>
      </div>
    </div>

  </div>
</section>
