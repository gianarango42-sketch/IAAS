---
import { Picture } from 'astro:assets';
import supervisionSite from '../assets/Equipo_de_2-3_202603190948.png';
---

<!-- SECTION 2: SUPERVISIÓN, INSPECCIÓN Y CONTROL TÉCNICO INTEGRAL -->
<section id='supervision' class='relative bg-iaas-bg overflow-hidden'>
  <!-- Stats Banner -->
  <div class='bg-white border-b border-gray-100'>
    <div class='max-w-7xl mx-auto px-6 sm:px-8 lg:px-12 py-8 sm:py-10'>
      <div class='grid grid-cols-2 lg:grid-cols-4 gap-6 lg:gap-8 reveal'>
        <div class='text-center group'>
          <div class='w-12 h-12 rounded-xl bg-iaas-light flex items-center justify-center mx-auto mb-3 group-hover:bg-iaas-blue transition-colors'>
            <svg class='w-5 h-5 text-iaas-blue group-hover:text-white transition-colors' fill='none' viewBox='0 0 24 24' stroke='currentColor' stroke-width='2'>
              <path stroke-linecap='round' stroke-linejoin='round' d='M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4'></path>
            </svg>
          </div>
          <p class='text-xl sm:text-2xl font-extrabold text-gray-900'>+500</p>
          <p class='text-[11px] text-iaas-gray mt-1'>Obras Supervisadas</p>
        </div>
        <div class='text-center group'>
          <div class='w-12 h-12 rounded-xl bg-iaas-light flex items-center justify-center mx-auto mb-3 group-hover:bg-iaas-blue transition-colors'>
            <svg class='w-5 h-5 text-iaas-blue group-hover:text-white transition-colors' fill='none' viewBox='0 0 24 24' stroke='currentColor' stroke-width='2'>
              <path stroke-linecap='round' stroke-linejoin='round' d='M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z'></path>
            </svg>
          </div>
          <p class='text-xl sm:text-2xl font-extrabold text-gray-900'>+120</p>
          <p class='text-[11px] text-iaas-gray mt-1'>Profesionales en Campo</p>
        </div>
        <div class='text-center group'>
          <div class='w-12 h-12 rounded-xl bg-iaas-light flex items-center justify-center mx-auto mb-3 group-hover:bg-iaas-blue transition-colors'>
            <svg class='w-5 h-5 text-iaas-blue group-hover:text-white transition-colors' fill='none' viewBox='0 0 24 24' stroke='currentColor' stroke-width='2'>
              <path stroke-linecap='round' stroke-linejoin='round' d='M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z'></path>
            </svg>
          </div>
          <p class='text-xl sm:text-2xl font-extrabold text-gray-900'>100%</p>
          <p class='text-[11px] text-iaas-gray mt-1'>Cumplimiento Normativo</p>
        </div>
        <div class='text-center group'>
          <div class='w-12 h-12 rounded-xl bg-iaas-light flex items-center justify-center mx-auto mb-3 group-hover:bg-iaas-blue transition-colors'>
            <svg class='w-5 h-5 text-iaas-blue group-hover:text-white transition-colors' fill='none' viewBox='0 0 24 24' stroke='currentColor' stroke-width='2'>
              <path stroke-linecap='round' stroke-linejoin='round' d='M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z'></path>
            </svg>
          </div>
          <p class='text-xl sm:text-2xl font-extrabold text-gray-900'>8</p>
          <p class='text-[11px] text-iaas-gray mt-1'>Regiones del Perú</p>
        </div>
      </div>
    </div>
  </div>

  <div class='max-w-7xl mx-auto px-6 sm:px-8 lg:px-12 py-12 sm:py-16 lg:py-20'>
    <!-- Section Header -->
    <div class='text-center mb-10 sm:mb-14 reveal'>
      <span class='inline-block px-4 py-1.5 text-[11px] font-bold text-iaas-blue bg-iaas-light rounded-full tracking-wider uppercase mb-4'>Servicio Principal</span>
      <h2
        class='text-2xl sm:text-3xl lg:text-[2.8rem] font-bold leading-tight text-gray-900 mb-4'
      >
        Supervisión, Inspección y
        <span class='text-iaas-blue block sm:inline'>Control Técnico Integrado (QHSE)</span>
      </h2>
      <p class='text-sm sm:text-base text-iaas-gray leading-relaxed max-w-2xl mx-auto'>
        Aseguramos la calidad y el cumplimiento contractual de sus obras mediante una supervisión integral.
      </p>
    </div>

    <div class='grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 items-center mb-14 sm:mb-20'>
      <!-- Left Column: Content -->
      <div class='reveal'>
        <!-- 2x2 Grid of Categories with descriptions -->
        <div class='grid grid-cols-1 sm:grid-cols-2 gap-5 mb-8'>
          <!-- Infraestructura Civil -->
          <div class='bg-white rounded-xl p-5 shadow-sm hover:shadow-md transition-all hover:-translate-y-0.5 group'>
            <div
              class='w-10 h-10 rounded-lg bg-iaas-light flex items-center justify-center mb-3 group-hover:bg-iaas-blue transition-colors'
            >
              <svg
                class='w-5 h-5 text-iaas-blue group-hover:text-white transition-colors'
                fill='none'
                viewBox='0 0 24 24'
                stroke='currentColor'
                stroke-width='2'
              >
                <path
                  stroke-linecap='round'
                  stroke-linejoin='round'
                  d='M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4'
                ></path>
              </svg>
            </div>
            <h3 class='text-sm font-bold text-gray-900 mb-1.5'>
              Calidad y Seguridad
            </h3>
            <p class='text-[11px] text-iaas-gray leading-relaxed'>
              Asegurando calidad, seguridad y medio ambiente. Garantizamos la excelencia de los materiales y procesos constructivos.
            </p>
          </div>

          <!-- Energía y Redes -->
          <div class='bg-white rounded-xl p-5 shadow-sm hover:shadow-md transition-all hover:-translate-y-0.5 group'>
            <div
              class='w-10 h-10 rounded-lg bg-iaas-light flex items-center justify-center mb-3 group-hover:bg-iaas-blue transition-colors'
            >
              <svg
                class='w-5 h-5 text-iaas-blue group-hover:text-white transition-colors'
                fill='none'
                viewBox='0 0 24 24'
                stroke='currentColor'
                stroke-width='2'
              >
                <path
                  stroke-linecap='round'
                  stroke-linejoin='round'
                  d='M13 10V3L4 14h7v7l9-11h-7z'></path>
              </svg>
            </div>
            <h3 class='text-sm font-bold text-gray-900 mb-1.5'>
              Planes QA/QC
            </h3>
            <p class='text-[11px] text-iaas-gray leading-relaxed'>
              Implementación de planes de aseguramiento y control de calidad (QA/QC).
            </p>
          </div>

          <!-- Minería e Industria -->
          <div class='bg-white rounded-xl p-5 shadow-sm hover:shadow-md transition-all hover:-translate-y-0.5 group'>
            <div
              class='w-10 h-10 rounded-lg bg-iaas-light flex items-center justify-center mb-3 group-hover:bg-iaas-blue transition-colors'
            >
              <svg
                class='w-5 h-5 text-iaas-blue group-hover:text-white transition-colors'
                fill='none'
                viewBox='0 0 24 24'
                stroke='currentColor'
                stroke-width='2'
              >
                <path
                  stroke-linecap='round'
                  stroke-linejoin='round'
                  d='M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z'
                ></path>
                <path
                  stroke-linecap='round'
                  stroke-linejoin='round'
                  d='M15 12a3 3 0 11-6 0 3 3 0 016 0z'></path>
              </svg>
            </div>
            <h3 class='text-sm font-bold text-gray-900 mb-1.5'>
              Ensayos de Laboratorio
            </h3>
            <p class='text-[11px] text-iaas-gray leading-relaxed'>
              Suelos, concreto, asfaltos y agregados. Pruebas no destructivas y control topográfico de alta precisión.
            </p>
          </div>

          <!-- Infraestructura Social -->
          <div class='bg-white rounded-xl p-5 shadow-sm hover:shadow-md transition-all hover:-translate-y-0.5 group'>
            <div
              class='w-10 h-10 rounded-lg bg-iaas-light flex items-center justify-center mb-3 group-hover:bg-iaas-blue transition-colors'
            >
              <svg
                class='w-5 h-5 text-iaas-blue group-hover:text-white transition-colors'
                fill='none'
                viewBox='0 0 24 24'
                stroke='currentColor'
                stroke-width='2'
              >
                <path
                  stroke-linecap='round'
                  stroke-linejoin='round'
                  d='M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z'
                ></path>
              </svg>
            </div>
            <h3 class='text-sm font-bold text-gray-900 mb-1.5'>
              Control Técnico
            </h3>
            <p class='text-[11px] text-iaas-gray leading-relaxed'>
              Control técnico de obras públicas y privadas.
            </p>
          </div>
        </div>

        <!-- Bottom Tabs -->
        <div class='flex flex-wrap gap-2'>
          <span
            class='px-4 py-2 text-xs font-semibold text-iaas-blue bg-iaas-light rounded-full hover:bg-iaas-blue hover:text-white transition-colors cursor-pointer'
            >Fiscalización</span
          >
          <span
            class='px-4 py-2 text-xs font-semibold text-iaas-blue bg-iaas-light rounded-full hover:bg-iaas-blue hover:text-white transition-colors cursor-pointer'
            >Consultoría</span
          >
          <span
            class='px-4 py-2 text-xs font-semibold text-iaas-blue bg-iaas-light rounded-full hover:bg-iaas-blue hover:text-white transition-colors cursor-pointer'
            >Interventoría</span
          >
        </div>
      </div>

      <!-- Right Column: Image -->
      <div class='relative rounded-2xl overflow-hidden shadow-lg reveal'>
        <div class='aspect-4/3'>
          <Picture
            src={supervisionSite}
            formats={['avif', 'webp']}
            alt='Equipo de supervisión en obra de construcción'
            class='w-full h-full object-cover'
            widths={[400, 800, 1200]}
            sizes='(max-width: 1024px) 100vw, 50vw'
            quality={80}
            loading='lazy'
          />
        </div>
        <!-- Overlay -->
        <div
          class='absolute inset-0 bg-linear-to-t from-iaas-dark/40 to-transparent'
        >
        </div>

        <!-- CONTROL INTEGRAL Badge with list -->
        <div
          class='absolute bottom-4 right-4 sm:bottom-6 sm:right-6 bg-white/95 backdrop-blur-sm rounded-xl px-5 py-4 shadow-lg'
        >
          <div class='flex items-center gap-3 mb-3'>
            <div
              class='w-10 h-10 rounded-full bg-iaas-blue flex items-center justify-center'
            >
              <svg
                class='w-5 h-5 text-white'
                fill='none'
                viewBox='0 0 24 24'
                stroke='currentColor'
                stroke-width='2'
              >
                <path
                  stroke-linecap='round'
                  stroke-linejoin='round'
                  d='M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z'
                ></path>
              </svg>
            </div>
            <p class='text-sm font-bold text-gray-900'>CONTROL INTEGRAL</p>
          </div>
          <ul class='space-y-2 text-[11px] text-iaas-gray'>
            <li class='flex items-center gap-2'>
              <svg class='w-3.5 h-3.5 text-green-500 shrink-0' fill='none' viewBox='0 0 24 24' stroke='currentColor' stroke-width='2.5'><path stroke-linecap='round' stroke-linejoin='round' d='M5 13l4 4L19 7'></path></svg>
              Técnico y Normativo
            </li>
            <li class='flex items-center gap-2'>
              <svg class='w-3.5 h-3.5 text-green-500 shrink-0' fill='none' viewBox='0 0 24 24' stroke='currentColor' stroke-width='2.5'><path stroke-linecap='round' stroke-linejoin='round' d='M5 13l4 4L19 7'></path></svg>
              Administrativo y Contractual
            </li>
            <li class='flex items-center gap-2'>
              <svg class='w-3.5 h-3.5 text-green-500 shrink-0' fill='none' viewBox='0 0 24 24' stroke='currentColor' stroke-width='2.5'><path stroke-linecap='round' stroke-linejoin='round' d='M5 13l4 4L19 7'></path></svg>
              Económico y Financiero
            </li>
          </ul>
        </div>
      </div>
    </div>

    <!-- Process Timeline -->
    <div class='reveal'>
      <h3 class='text-lg sm:text-xl font-bold text-gray-900 text-center mb-8'>
        Nuestro <span class='text-iaas-blue'>Proceso de Supervisión</span>
      </h3>
      <div class='grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6'>
        <!-- Step 1 -->
        <div class='relative text-center group'>
          <div class='w-14 h-14 rounded-2xl bg-iaas-blue text-white flex items-center justify-center mx-auto mb-4 text-lg font-extrabold group-hover:scale-110 transition-transform'>01</div>
          <h4 class='text-sm font-bold text-gray-900 mb-2'>Pre-inversión</h4>
          <p class='text-[11px] text-iaas-gray leading-relaxed'>Revisión de expedientes técnicos, factibilidad y análisis de riesgos del proyecto.</p>
          <!-- Connector line (hidden on mobile/last item) -->
          <div class='hidden lg:block absolute top-7 left-[calc(50%+35px)] w-[calc(100%-70px)] h-0.5 bg-iaas-blue/20'></div>
        </div>
        <!-- Step 2 -->
        <div class='relative text-center group'>
          <div class='w-14 h-14 rounded-2xl bg-iaas-blue text-white flex items-center justify-center mx-auto mb-4 text-lg font-extrabold group-hover:scale-110 transition-transform'>02</div>
          <h4 class='text-sm font-bold text-gray-900 mb-2'>Ejecución</h4>
          <p class='text-[11px] text-iaas-gray leading-relaxed'>Control permanente de calidad, plazos, costos y cumplimiento contractual en campo.</p>
          <div class='hidden lg:block absolute top-7 left-[calc(50%+35px)] w-[calc(100%-70px)] h-0.5 bg-iaas-blue/20'></div>
        </div>
        <!-- Step 3 -->
        <div class='relative text-center group'>
          <div class='w-14 h-14 rounded-2xl bg-iaas-blue text-white flex items-center justify-center mx-auto mb-4 text-lg font-extrabold group-hover:scale-110 transition-transform'>03</div>
          <h4 class='text-sm font-bold text-gray-900 mb-2'>Liquidación</h4>
          <p class='text-[11px] text-iaas-gray leading-relaxed'>Verificación de metrados finales, valorización de obra y cierre administrativo.</p>
          <div class='hidden lg:block absolute top-7 left-[calc(50%+35px)] w-[calc(100%-70px)] h-0.5 bg-iaas-blue/20'></div>
        </div>
        <!-- Step 4 -->
        <div class='relative text-center group'>
          <div class='w-14 h-14 rounded-2xl bg-iaas-blue text-white flex items-center justify-center mx-auto mb-4 text-lg font-extrabold group-hover:scale-110 transition-transform'>04</div>
          <h4 class='text-sm font-bold text-gray-900 mb-2'>Mantenimiento</h4>
          <p class='text-[11px] text-iaas-gray leading-relaxed'>Seguimiento post-construcción para asegurar durabilidad y funcionamiento óptimo.</p>
        </div>
      </div>
    </div>

    <!-- Testimonial -->
    <div class='mt-14 sm:mt-20 reveal'>
      <div class='bg-iaas-dark rounded-2xl p-8 sm:p-10 lg:p-12 text-center relative overflow-hidden'>
        <!-- Decorative -->
        <div class='absolute top-0 left-0 w-32 h-32 bg-iaas-blue/10 rounded-full -translate-x-1/2 -translate-y-1/2'></div>
        <div class='absolute bottom-0 right-0 w-40 h-40 bg-iaas-blue/10 rounded-full translate-x-1/2 translate-y-1/2'></div>

        <div class='relative'>
          <svg class='w-8 h-8 text-iaas-blue/40 mx-auto mb-4' fill='currentColor' viewBox='0 0 24 24'><path d='M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z'></path></svg>
          <blockquote class='text-base sm:text-lg text-white/90 italic leading-relaxed max-w-3xl mx-auto mb-6'>
            "Nuestro trabajo abarca desde la pre-inversión hasta el
            mantenimiento, asegurando cumplimiento normativo y eficiencia
            financiera en sectores público y privado. IAAS se distingue por su
            compromiso con la excelencia y su enfoque integral en cada proyecto."
          </blockquote>
          <div>
            <p class='text-sm font-bold text-white'>Dirección de Proyectos</p>
            <p class='text-[11px] text-white/60'>IAAS - Consultoría en Gestión Integral</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
