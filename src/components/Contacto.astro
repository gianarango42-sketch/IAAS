<!-- SECTION: CONTACTO / CTA -->
<section id='contacto' class='relative bg-white overflow-hidden'>
  <div class='max-w-7xl mx-auto px-6 sm:px-8 lg:px-12 py-14 sm:py-20 lg:py-24'>
    <div class='grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-center'>
      <!-- Left: CTA Content -->
      <div class='reveal'>
        <span class='inline-block px-4 py-1.5 text-[11px] font-bold text-iaas-blue bg-iaas-light rounded-full tracking-wider uppercase mb-4'>Trabajemos Juntos</span>
        <h2 class='text-2xl sm:text-3xl lg:text-4xl font-bold leading-tight text-gray-900 mb-4'>
          ¿Tiene un proyecto en <span class='text-iaas-blue'>mente?</span>
        </h2>
        <p class='text-sm sm:text-base text-iaas-gray leading-relaxed mb-8 max-w-lg'>
          Nuestro equipo de profesionales está listo para acompañarlo desde la planificación hasta la entrega final. Solicite una cotización sin compromiso.
        </p>

        <!-- Contact info cards -->
        <div class='space-y-4 mb-8'>
          <a href='mailto:proyectos@iaasperu.com' class='flex items-center gap-4 bg-iaas-bg rounded-xl p-4 hover:shadow-md transition-all group'>
            <div class='w-11 h-11 rounded-lg bg-iaas-blue flex items-center justify-center shrink-0 group-hover:scale-110 transition-transform'>
              <svg class='w-5 h-5 text-white' fill='none' viewBox='0 0 24 24' stroke='currentColor' stroke-width='2'>
                <path stroke-linecap='round' stroke-linejoin='round' d='M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z'></path>
              </svg>
            </div>
            <div>
              <p class='text-xs font-bold text-gray-900'>Correo Electrónico</p>
              <p class='text-sm text-iaas-blue'>proyectos@iaasperu.com</p>
            </div>
          </a>

          <a href='tel:+51999999999' class='flex items-center gap-4 bg-iaas-bg rounded-xl p-4 hover:shadow-md transition-all group'>
            <div class='w-11 h-11 rounded-lg bg-iaas-blue flex items-center justify-center shrink-0 group-hover:scale-110 transition-transform'>
              <svg class='w-5 h-5 text-white' fill='none' viewBox='0 0 24 24' stroke='currentColor' stroke-width='2'>
                <path stroke-linecap='round' stroke-linejoin='round' d='M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z'></path>
              </svg>
            </div>
            <div>
              <p class='text-xs font-bold text-gray-900'>Teléfono</p>
              <p class='text-sm text-iaas-blue'>+51 999 999 999</p>
            </div>
          </a>

          <a href='https://www.iaasperu.com' target='_blank' rel='noopener' class='flex items-center gap-4 bg-iaas-bg rounded-xl p-4 hover:shadow-md transition-all group'>
            <div class='w-11 h-11 rounded-lg bg-iaas-blue flex items-center justify-center shrink-0 group-hover:scale-110 transition-transform'>
              <svg class='w-5 h-5 text-white' fill='none' viewBox='0 0 24 24' stroke='currentColor' stroke-width='2'>
                <path stroke-linecap='round' stroke-linejoin='round' d='M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9'></path>
              </svg>
            </div>
            <div>
              <p class='text-xs font-bold text-gray-900'>Sitio Web</p>
              <p class='text-sm text-iaas-blue'>www.iaasperu.com</p>
            </div>
          </a>
        </div>
      </div>

      <!-- Right: Contact Form -->
      <div class='reveal'>
        <div class='bg-iaas-bg rounded-2xl p-6 sm:p-8 lg:p-10'>
          <h3 class='text-lg font-bold text-gray-900 mb-6'>Solicite una cotización</h3>
          <form class='space-y-4' id='contact-form'>
            <div class='grid grid-cols-1 sm:grid-cols-2 gap-4'>
              <div>
                <label for='nombre' class='block text-[11px] font-semibold text-gray-700 mb-1.5'>Nombre completo</label>
                <input type='text' id='nombre' name='nombre' required
                  class='w-full px-4 py-2.5 text-sm rounded-lg border border-gray-200 focus:border-iaas-blue focus:ring-2 focus:ring-iaas-blue/20 outline-none transition-all bg-white'
                  placeholder='Su nombre'
                />
              </div>
              <div>
                <label for='empresa' class='block text-[11px] font-semibold text-gray-700 mb-1.5'>Empresa</label>
                <input type='text' id='empresa' name='empresa'
                  class='w-full px-4 py-2.5 text-sm rounded-lg border border-gray-200 focus:border-iaas-blue focus:ring-2 focus:ring-iaas-blue/20 outline-none transition-all bg-white'
                  placeholder='Nombre de empresa'
                />
              </div>
            </div>
            <div class='grid grid-cols-1 sm:grid-cols-2 gap-4'>
              <div>
                <label for='email' class='block text-[11px] font-semibold text-gray-700 mb-1.5'>Correo electrónico</label>
                <input type='email' id='email' name='email' required
                  class='w-full px-4 py-2.5 text-sm rounded-lg border border-gray-200 focus:border-iaas-blue focus:ring-2 focus:ring-iaas-blue/20 outline-none transition-all bg-white'
                  placeholder='correo@empresa.com'
                />
              </div>
              <div>
                <label for='telefono' class='block text-[11px] font-semibold text-gray-700 mb-1.5'>Teléfono</label>
                <input type='tel' id='telefono' name='telefono'
                  class='w-full px-4 py-2.5 text-sm rounded-lg border border-gray-200 focus:border-iaas-blue focus:ring-2 focus:ring-iaas-blue/20 outline-none transition-all bg-white'
                  placeholder='+51 999 999 999'
                />
              </div>
            </div>
            <div>
              <label for='servicio' class='block text-[11px] font-semibold text-gray-700 mb-1.5'>Servicio de interés</label>
              <select id='servicio' name='servicio'
                class='w-full px-4 py-2.5 text-sm rounded-lg border border-gray-200 focus:border-iaas-blue focus:ring-2 focus:ring-iaas-blue/20 outline-none transition-all bg-white text-iaas-gray'
              >
                <option value=''>Seleccione un servicio</option>
                <option value='gerencia'>Gerencia de Proyectos (Project Management)</option>
                <option value='supervision'>Supervisión, Inspección y Control Técnico (QHSE)</option>
                <option value='ingenieria'>Ingeniería, Diseño y Expedientes Técnicos</option>
                <option value='obras'>Ejecución de Obras y Desarrollo Inmobiliario</option>
                <option value='sst'>Gestión de Seguridad, Salud en el Trabajo (SST)</option>
                <option value='ambiental'>Gestión Ambiental</option>
                <option value='calidad'>Gestión de Calidad</option>
              </select>
            </div>
            <div>
              <label for='mensaje' class='block text-[11px] font-semibold text-gray-700 mb-1.5'>Mensaje</label>
              <textarea id='mensaje' name='mensaje' rows='4'
                class='w-full px-4 py-2.5 text-sm rounded-lg border border-gray-200 focus:border-iaas-blue focus:ring-2 focus:ring-iaas-blue/20 outline-none transition-all bg-white resize-none'
                placeholder='Describa brevemente su proyecto...'
              ></textarea>
            </div>
            <button type='submit'
              class='w-full px-6 py-3 text-sm font-bold text-white bg-iaas-blue rounded-lg hover:bg-iaas-dark transition-all hover:shadow-lg hover:shadow-iaas-blue/25 cursor-pointer'
            >
              Enviar Solicitud
            </button>
            <p class='text-[10px] text-iaas-gray text-center'>Responderemos en un plazo máximo de 24 horas hábiles.</p>
            <!-- Success/Error messages -->
            <div id='form-success' class='hidden p-4 bg-green-50 border border-green-200 rounded-lg text-center'>
              <p class='text-sm font-semibold text-green-800'>Solicitud enviada correctamente.</p>
              <p class='text-[11px] text-green-600 mt-1'>Nos pondremos en contacto pronto.</p>
            </div>
            <div id='form-error' class='hidden p-4 bg-red-50 border border-red-200 rounded-lg text-center'>
              <p class='text-sm font-semibold text-red-800'>Error al enviar el mensaje.</p>
              <p class='text-[11px] text-red-600 mt-1'>Por favor, intente nuevamente o contáctenos por WhatsApp.</p>
            </div>
          </form>

          <script>
            document.getElementById('contact-form')?.addEventListener('submit', async (e) => {
              e.preventDefault();
              const form = e.target as HTMLFormElement;
              const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
              const successEl = document.getElementById('form-success');
              const errorEl = document.getElementById('form-error');

              successEl?.classList.add('hidden');
              errorEl?.classList.add('hidden');
              btn.disabled = true;
              btn.textContent = 'Enviando...';

              try {
                const formData = {
                  nombre: (form.querySelector('#nombre') as HTMLInputElement).value,
                  empresa: (form.querySelector('#empresa') as HTMLInputElement).value,
                  email: (form.querySelector('#email') as HTMLInputElement).value,
                  telefono: (form.querySelector('#telefono') as HTMLInputElement).value,
                  servicio: (form.querySelector('#servicio') as HTMLSelectElement).value,
                  mensaje: (form.querySelector('#mensaje') as HTMLTextAreaElement).value,
                };

                const res = await fetch('/api/contact', {
                  method: 'POST',
                  headers: { 'Content-Type': 'application/json' },
                  body: JSON.stringify(formData),
                });

                if (res.ok) {
                  successEl?.classList.remove('hidden');
                  form.reset();
                } else {
                  errorEl?.classList.remove('hidden');
                }
              } catch {
                errorEl?.classList.remove('hidden');
              } finally {
                btn.disabled = false;
                btn.textContent = 'Enviar Solicitud';
              }
            });
          </script>
        </div>
      </div>
    </div>
  </div>
</section>
