---
import { Picture } from 'astro:assets';
import labTesting from '../assets/Laboratorio_de_materiales__202603190949.png';
---

<!-- SECTION: GESTIÓN DE CALIDAD -->
<section id='calidad' class='relative bg-iaas-bg overflow-hidden'>
  <div class='max-w-7xl mx-auto px-6 sm:px-8 lg:px-12 py-12 sm:py-16 lg:py-20'>
    <div class='grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 items-center'>
      <!-- Left Column: Content -->
      <div>
        <!-- Label -->
        <div class='inline-flex items-center gap-2 mb-4'>
          <div class='w-8 h-px bg-iaas-blue'></div>
          <span class='text-[11px] font-bold text-iaas-blue tracking-[0.2em] uppercase'>ISO 9001</span>
        </div>

        <!-- Title -->
        <h2
          class='text-2xl sm:text-3xl lg:text-4xl font-bold leading-tight text-gray-900 mb-4'
        >
          Gestión de
          <span class='text-iaas-blue block'>Calidad</span>
        </h2>

        <!-- Subtitle -->
        <p class='text-sm text-iaas-gray leading-relaxed mb-8 max-w-lg'>
          Implementación de sistemas de gestión ISO 9001 para asegurar la calidad en todos los procesos.
        </p>

        <!-- 2x2 Grid of Services -->
        <div class='grid grid-cols-1 sm:grid-cols-2 gap-4'>
          <div class='group bg-white rounded-xl p-5 shadow-sm hover:shadow-md transition-all hover:-translate-y-0.5 border border-gray-100'>
            <div class='w-9 h-9 rounded-lg bg-iaas-blue/10 flex items-center justify-center mb-3 group-hover:bg-iaas-blue transition-colors'>
              <svg class='w-4 h-4 text-iaas-blue group-hover:text-white transition-colors' fill='none' viewBox='0 0 24 24' stroke='currentColor' stroke-width='2'>
                <path stroke-linecap='round' stroke-linejoin='round' d='M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z'></path>
              </svg>
            </div>
            <h3 class='text-sm font-bold text-gray-900 mb-1'>Implementación ISO 9001</h3>
            <p class='text-[11px] text-iaas-gray leading-relaxed'>Implementación de sistemas de gestión de calidad bajo la norma ISO 9001.</p>
          </div>

          <div class='group bg-white rounded-xl p-5 shadow-sm hover:shadow-md transition-all hover:-translate-y-0.5 border border-gray-100'>
            <div class='w-9 h-9 rounded-lg bg-iaas-blue/10 flex items-center justify-center mb-3 group-hover:bg-iaas-blue transition-colors'>
              <svg class='w-4 h-4 text-iaas-blue group-hover:text-white transition-colors' fill='none' viewBox='0 0 24 24' stroke='currentColor' stroke-width='2'>
                <path stroke-linecap='round' stroke-linejoin='round' d='M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z'></path>
              </svg>
            </div>
            <h3 class='text-sm font-bold text-gray-900 mb-1'>Consultoría para Certificación</h3>
            <p class='text-[11px] text-iaas-gray leading-relaxed'>Consultoría para certificación ISO 9001 en su organización.</p>
          </div>

          <div class='group bg-white rounded-xl p-5 shadow-sm hover:shadow-md transition-all hover:-translate-y-0.5 border border-gray-100'>
            <div class='w-9 h-9 rounded-lg bg-iaas-blue/10 flex items-center justify-center mb-3 group-hover:bg-iaas-blue transition-colors'>
              <svg class='w-4 h-4 text-iaas-blue group-hover:text-white transition-colors' fill='none' viewBox='0 0 24 24' stroke='currentColor' stroke-width='2'>
                <path stroke-linecap='round' stroke-linejoin='round' d='M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z'></path>
              </svg>
            </div>
            <h3 class='text-sm font-bold text-gray-900 mb-1'>Homologación de Proveedores</h3>
            <p class='text-[11px] text-iaas-gray leading-relaxed'>Evaluación y homologación de proveedores bajo estándares de calidad.</p>
          </div>

          <div class='group bg-white rounded-xl p-5 shadow-sm hover:shadow-md transition-all hover:-translate-y-0.5 border border-gray-100'>
            <div class='w-9 h-9 rounded-lg bg-iaas-blue/10 flex items-center justify-center mb-3 group-hover:bg-iaas-blue transition-colors'>
              <svg class='w-4 h-4 text-iaas-blue group-hover:text-white transition-colors' fill='none' viewBox='0 0 24 24' stroke='currentColor' stroke-width='2'>
                <path stroke-linecap='round' stroke-linejoin='round' d='M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4'></path>
              </svg>
            </div>
            <h3 class='text-sm font-bold text-gray-900 mb-1'>Auditorías</h3>
            <p class='text-[11px] text-iaas-gray leading-relaxed'>Auditorías internas y externas para verificar el cumplimiento del sistema de gestión de calidad.</p>
          </div>
        </div>
      </div>

      <!-- Right Column: Image -->
      <div class='relative rounded-2xl overflow-hidden shadow-lg'>
        <div class='aspect-4/3'>
          <Picture
            src={labTesting}
            formats={['avif', 'webp']}
            alt='Control de calidad y ensayos de laboratorio'
            class='w-full h-full object-cover'
            widths={[400, 800, 1200]}
            sizes='(max-width: 1024px) 100vw, 50vw'
            quality={80}
            loading='lazy'
          />
        </div>
        <div class='absolute inset-0 bg-linear-to-t from-iaas-dark/20 to-transparent'></div>
      </div>
    </div>
  </div>
</section>
