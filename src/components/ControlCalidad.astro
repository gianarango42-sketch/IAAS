---
import { Picture } from 'astro:assets';
import labTesting from '../assets/Laboratorio_de_materiales__202603190949.png';
---

<!-- SECTION 6: CONTROL DE CALIDAD Y ENSAYOS DE LABORATORIO -->
<section id='calidad' class='relative bg-iaas-bg overflow-hidden'>
  <div class='max-w-7xl mx-auto px-6 sm:px-8 lg:px-12 py-12 sm:py-16 lg:py-20'>
    <div class='grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 items-center'>
      <!-- Left Column: Content -->
      <div>
        <!-- Label -->
        <span
          class='text-[10px] sm:text-xs font-semibold tracking-widest text-iaas-gray uppercase mb-4 block'
          >Excelencia Técnica</span
        >

        <!-- Title -->
        <h2
          class='text-2xl sm:text-3xl lg:text-4xl font-bold leading-tight text-gray-900 mb-4'
        >
          Control de Calidad y
          <span class='text-iaas-blue block'>Ensayos de Laboratorio</span>
        </h2>

        <!-- Subtitle -->
        <p class='text-sm text-iaas-gray leading-relaxed mb-8 max-w-lg'>
          Aseguramos la integridad estructural y la calidad de los materiales
          mediante procesos rigurosos de QA/QC.
        </p>

        <!-- 2x2 Grid of Services -->
        <div class='grid grid-cols-1 sm:grid-cols-2 gap-6'>
          <!-- Ensayos de Materiales -->
          <div class='flex items-start gap-3 group'>
            <div
              class='w-9 h-9 rounded-lg bg-iaas-light flex items-center justify-center shrink-0 mt-0.5 group-hover:bg-iaas-blue transition-colors'
            >
              <svg
                class='w-4 h-4 text-iaas-blue group-hover:text-white transition-colors'
                fill='none'
                viewBox='0 0 24 24'
                stroke='currentColor'
                stroke-width='2'
              >
                <path
                  stroke-linecap='round'
                  stroke-linejoin='round'
                  d='M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z'
                ></path>
              </svg>
            </div>
            <div>
              <h3 class='text-sm font-bold text-gray-900 mb-1'>
                Ensayos de Materiales
              </h3>
              <p class='text-[11px] text-iaas-gray leading-relaxed'>
                Concreto, suelos, agregados, acero y mezclas asfálticas bajo
                normas técnicas.
              </p>
            </div>
          </div>

          <!-- Aseguramiento QA/QC -->
          <div class='flex items-start gap-3 group'>
            <div
              class='w-9 h-9 rounded-lg bg-iaas-light flex items-center justify-center shrink-0 mt-0.5 group-hover:bg-iaas-blue transition-colors'
            >
              <svg
                class='w-4 h-4 text-iaas-blue group-hover:text-white transition-colors'
                fill='none'
                viewBox='0 0 24 24'
                stroke='currentColor'
                stroke-width='2'
              >
                <path
                  stroke-linecap='round'
                  stroke-linejoin='round'
                  d='M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z'></path>
              </svg>
            </div>
            <div>
              <h3 class='text-sm font-bold text-gray-900 mb-1'>
                Aseguramiento QA/QC
              </h3>
              <p class='text-[11px] text-iaas-gray leading-relaxed'>
                Protocolos de aseguramiento y control de calidad en todas las
                etapas constructivas.
              </p>
            </div>
          </div>

          <!-- Control Topográfico -->
          <div class='flex items-start gap-3 group'>
            <div
              class='w-9 h-9 rounded-lg bg-iaas-light flex items-center justify-center shrink-0 mt-0.5 group-hover:bg-iaas-blue transition-colors'
            >
              <svg
                class='w-4 h-4 text-iaas-blue group-hover:text-white transition-colors'
                fill='none'
                viewBox='0 0 24 24'
                stroke='currentColor'
                stroke-width='2'
              >
                <path
                  stroke-linecap='round'
                  stroke-linejoin='round'
                  d='M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7'
                ></path>
              </svg>
            </div>
            <div>
              <h3 class='text-sm font-bold text-gray-900 mb-1'>
                Control Topográfico
              </h3>
              <p class='text-[11px] text-iaas-gray leading-relaxed'>
                Levantamientos, replanteos y monitoreo de deformaciones con
                estación total y GPS.
              </p>
            </div>
          </div>

          <!-- Pruebas Especiales -->
          <div class='flex items-start gap-3 group'>
            <div
              class='w-9 h-9 rounded-lg bg-iaas-light flex items-center justify-center shrink-0 mt-0.5 group-hover:bg-iaas-blue transition-colors'
            >
              <svg
                class='w-4 h-4 text-iaas-blue group-hover:text-white transition-colors'
                fill='none'
                viewBox='0 0 24 24'
                stroke='currentColor'
                stroke-width='2'
              >
                <path
                  stroke-linecap='round'
                  stroke-linejoin='round'
                  d='M13 10V3L4 14h7v7l9-11h-7z'></path>
              </svg>
            </div>
            <div>
              <h3 class='text-sm font-bold text-gray-900 mb-1'>
                Pruebas Especiales
              </h3>
              <p class='text-[11px] text-iaas-gray leading-relaxed'>
                Pruebas de carga, ensayos no destructivos, esclerometría y
                ultrasonido.
              </p>
            </div>
          </div>
        </div>
      </div>

      <!-- Right Column: Image -->
      <div class='relative rounded-2xl overflow-hidden shadow-lg'>
        <div class='aspect-4/3'>
          <Picture
            src={labTesting}
            formats={['avif', 'webp']}
            alt='Máquina de ensayos de laboratorio para control de calidad de materiales'
            class='w-full h-full object-cover'
            widths={[400, 800, 1200]}
            sizes='(max-width: 1024px) 100vw, 50vw'
          />
        </div>
        <!-- Overlay -->
        <div
          class='absolute inset-0 bg-linear-to-t from-iaas-dark/20 to-transparent'
        >
        </div>

        <!-- 0% Stat Badge -->
        <div
          class='absolute bottom-4 right-4 sm:bottom-6 sm:right-6 bg-white/95 backdrop-blur-sm rounded-lg px-5 py-4 shadow-lg text-center'
        >
          <p
            class='text-3xl sm:text-4xl font-extrabold text-iaas-blue leading-none'
          >
            0%
          </p>
          <p class='text-[10px] sm:text-[11px] text-iaas-gray font-medium mt-1'>
            Tolerancia a<br />defectos críticos
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
