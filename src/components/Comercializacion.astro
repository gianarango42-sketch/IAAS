---
import { Picture } from 'astro:assets';
import heavyMachinery from '../assets/No_tantas_maquinarias._202603190949.png';
---

<!-- SECTION 9: COMERCIALIZACIÓN Y SERVICIOS COMPLEMENTARIOS -->
<section id='comercializacion' class='relative bg-white overflow-hidden'>
  <div class='max-w-7xl mx-auto px-6 sm:px-8 lg:px-12 py-12 sm:py-16 lg:py-20'>
    <!-- Header -->
    <div class='flex items-start justify-between mb-6 sm:mb-8'>
      <div class='max-w-xl'>
        <h2
          class='text-2xl sm:text-3xl lg:text-[2.6rem] font-bold leading-tight text-gray-900 mb-4'
        >
          Comercialización y <span class='text-iaas-blue'
            >Servicios Complementarios</span
          >
        </h2>
        <p class='text-sm text-iaas-gray leading-relaxed'>
          Suministro estratégico de equipos y maquinaria esencial para el éxito
          operativo en construcción y monitoreo ambiental.
        </p>
      </div>
    </div>

    <!-- Image + Cards overlay -->
    <div class='relative mb-10'>
      <!-- Background Image -->
      <div class='relative rounded-2xl overflow-hidden h-64 sm:h-80 lg:h-96'>
        <Picture
          src={heavyMachinery}
          formats={['avif', 'webp']}
          alt='Flota de maquinaria pesada para construcción'
          class='w-full h-full object-cover'
          widths={[600, 1200, 1800]}
          sizes='(max-width: 768px) 100vw, 1200px'
          quality={80}
          loading='lazy'
        />
        <div
          class='absolute inset-0 bg-linear-to-t from-iaas-dark/60 via-iaas-dark/20 to-transparent'
        >
        </div>
      </div>

      <!-- 3 Cards overlapping the image -->
      <div class='relative -mt-24 sm:-mt-32 lg:-mt-40 px-2 sm:px-4'>
        <div
          class='grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-5'
        >
          <!-- Card 1: Maquinaria Pesada -->
          <div
            class='bg-white/95 backdrop-blur-sm rounded-xl p-5 sm:p-6 shadow-lg border border-gray-100'
          >
            <div class='flex items-center gap-2.5 mb-3'>
              <div
                class='w-8 h-8 rounded-lg bg-iaas-light flex items-center justify-center'
              >
                <svg
                  class='w-4 h-4 text-iaas-blue'
                  fill='none'
                  viewBox='0 0 24 24'
                  stroke='currentColor'
                  stroke-width='2'
                >
                  <path
                    stroke-linecap='round'
                    stroke-linejoin='round'
                    d='M13 10V3L4 14h7v7l9-11h-7z'></path>
                </svg>
              </div>
              <h3 class='text-sm font-bold text-gray-900'>Maquinaria Pesada</h3>
            </div>
            <p class='text-[11px] text-iaas-gray leading-relaxed mb-3'>
              Venta, alquiler y leasing de maquinaria pesada, equipos y
              herramientas especializadas.
            </p>
            <div class='space-y-1.5'>
              <div class='flex items-center gap-2 text-[11px] text-iaas-gray'>
                <svg
                  class='w-3.5 h-3.5 text-iaas-blue shrink-0'
                  fill='none'
                  viewBox='0 0 24 24'
                  stroke='currentColor'
                  stroke-width='2'
                  ><path
                    stroke-linecap='round'
                    stroke-linejoin='round'
                    d='M5 13l4 4L19 7'></path></svg
                >
                <span class='font-semibold uppercase tracking-wider'
                  >Arrendamiento</span
                >
              </div>
              <div class='flex items-center gap-2 text-[11px] text-iaas-gray'>
                <svg
                  class='w-3.5 h-3.5 text-iaas-blue shrink-0'
                  fill='none'
                  viewBox='0 0 24 24'
                  stroke='currentColor'
                  stroke-width='2'
                  ><path
                    stroke-linecap='round'
                    stroke-linejoin='round'
                    d='M5 13l4 4L19 7'></path></svg
                >
                <span class='font-semibold uppercase tracking-wider'
                  >Mantenimiento</span
                >
              </div>
            </div>
          </div>

          <!-- Card 2: Seguridad Industrial -->
          <div
            class='bg-white/95 backdrop-blur-sm rounded-xl p-5 sm:p-6 shadow-lg border border-gray-100'
          >
            <div class='flex items-center gap-2.5 mb-3'>
              <div
                class='w-8 h-8 rounded-lg bg-iaas-light flex items-center justify-center'
              >
                <svg
                  class='w-4 h-4 text-iaas-blue'
                  fill='none'
                  viewBox='0 0 24 24'
                  stroke='currentColor'
                  stroke-width='2'
                >
                  <path
                    stroke-linecap='round'
                    stroke-linejoin='round'
                    d='M20.618 5.984A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z'
                  ></path>
                </svg>
              </div>
              <h3 class='text-sm font-bold text-gray-900'>
                Seguridad Industrial
              </h3>
            </div>
            <p class='text-[11px] text-iaas-gray leading-relaxed mb-3'>
              Distribución de equipos de protección personal (EPP) y sistemas de
              seguridad colectiva.
            </p>
            <div class='space-y-1.5'>
              <div class='flex items-center gap-2 text-[11px] text-iaas-gray'>
                <svg
                  class='w-3.5 h-3.5 text-iaas-blue shrink-0'
                  fill='none'
                  viewBox='0 0 24 24'
                  stroke='currentColor'
                  stroke-width='2'
                  ><path
                    stroke-linecap='round'
                    stroke-linejoin='round'
                    d='M5 13l4 4L19 7'></path></svg
                >
                <span class='font-semibold uppercase tracking-wider'
                  >Importación Directa</span
                >
              </div>
              <div class='flex items-center gap-2 text-[11px] text-iaas-gray'>
                <svg
                  class='w-3.5 h-3.5 text-iaas-blue shrink-0'
                  fill='none'
                  viewBox='0 0 24 24'
                  stroke='currentColor'
                  stroke-width='2'
                  ><path
                    stroke-linecap='round'
                    stroke-linejoin='round'
                    d='M5 13l4 4L19 7'></path></svg
                >
                <span class='font-semibold uppercase tracking-wider'
                  >Certificación</span
                >
              </div>
            </div>
          </div>

          <!-- Card 3: Instrumentos -->
          <div
            class='bg-white/95 backdrop-blur-sm rounded-xl p-5 sm:p-6 shadow-lg border border-gray-100 sm:col-span-2 lg:col-span-1'
          >
            <div class='flex items-center gap-2.5 mb-3'>
              <div
                class='w-8 h-8 rounded-lg bg-iaas-light flex items-center justify-center'
              >
                <svg
                  class='w-4 h-4 text-iaas-blue'
                  fill='none'
                  viewBox='0 0 24 24'
                  stroke='currentColor'
                  stroke-width='2'
                >
                  <path
                    stroke-linecap='round'
                    stroke-linejoin='round'
                    d='M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z'
                  ></path>
                </svg>
              </div>
              <h3 class='text-sm font-bold text-gray-900'>Instrumentos</h3>
            </div>
            <p class='text-[11px] text-iaas-gray leading-relaxed mb-3'>
              Equipos de medición para monitoreo ambiental, higiene ocupacional
              y control topográfico.
            </p>
            <div class='space-y-1.5'>
              <div class='flex items-center gap-2 text-[11px] text-iaas-gray'>
                <svg
                  class='w-3.5 h-3.5 text-iaas-blue shrink-0'
                  fill='none'
                  viewBox='0 0 24 24'
                  stroke='currentColor'
                  stroke-width='2'
                  ><path
                    stroke-linecap='round'
                    stroke-linejoin='round'
                    d='M5 13l4 4L19 7'></path></svg
                >
                <span class='font-semibold uppercase tracking-wider'
                  >Calibración</span
                >
              </div>
              <div class='flex items-center gap-2 text-[11px] text-iaas-gray'>
                <svg
                  class='w-3.5 h-3.5 text-iaas-blue shrink-0'
                  fill='none'
                  viewBox='0 0 24 24'
                  stroke='currentColor'
                  stroke-width='2'
                  ><path
                    stroke-linecap='round'
                    stroke-linejoin='round'
                    d='M5 13l4 4L19 7'></path></svg
                >
                <span class='font-semibold uppercase tracking-wider'
                  >Asesoría Técnica</span
                >
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Bottom Steps -->
    <div class='flex flex-wrap items-end gap-8 sm:gap-12'>
      <div class='flex items-baseline gap-2'>
        <span
          class='text-3xl sm:text-4xl font-extrabold text-iaas-blue/20 leading-none'
          >01.</span
        >
        <span
          class='text-xs sm:text-sm font-bold text-iaas-dark tracking-wider uppercase'
          >Importación</span
        >
      </div>
      <div class='flex items-baseline gap-2'>
        <span
          class='text-3xl sm:text-4xl font-extrabold text-iaas-blue/20 leading-none'
          >02.</span
        >
        <span
          class='text-xs sm:text-sm font-bold text-iaas-dark tracking-wider uppercase'
          >Venta</span
        >
      </div>
      <div class='flex items-baseline gap-2'>
        <span
          class='text-3xl sm:text-4xl font-extrabold text-iaas-blue/20 leading-none'
          >03.</span
        >
        <span
          class='text-xs sm:text-sm font-bold text-iaas-dark tracking-wider uppercase'
          >Alquiler</span
        >
      </div>
    </div>
  </div>
</section>
