---
import { Picture } from 'astro:assets';
import engineeringBuilding from '../assets/Edificio_moderno_terminado_202603190949.png';
---

<!-- SECTION 8: INGENIERÍA, DISEÑO Y EXPEDIENTES TÉCNICOS -->
<section id='ingenieria' class='relative bg-iaas-bg overflow-hidden'>
  <div class='max-w-7xl mx-auto px-6 sm:px-8 lg:px-12 py-12 sm:py-16 lg:py-20'>
    <div class='grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 items-center'>
      <!-- Left Column: Content -->
      <div>
        <!-- Label -->
        <span
          class='text-[10px] sm:text-xs font-semibold tracking-widest text-iaas-gray uppercase mb-6 block'
          >Servicios de Consultoría</span
        >

        <!-- Title -->
        <h2
          class='text-2xl sm:text-3xl lg:text-[2.6rem] font-bold leading-tight text-gray-900 mb-4'
        >
          Ingeniería, Diseño y
          <span class='text-iaas-blue block'>Expedientes Técnicos</span>
        </h2>

        <!-- Subtitle -->
        <p class='text-sm text-iaas-gray leading-relaxed mb-8 max-w-lg'>
          Desarrollamos soluciones de ingeniería integral, desde la concepción
          básica hasta el detalle constructivo, asegurando precisión técnica y
          viabilidad económica.
        </p>

        <!-- 2x2 Grid of Services -->
        <div class='grid grid-cols-1 sm:grid-cols-2 gap-5 mb-10'>
          <!-- Estudios Definitivos -->
          <div class='flex items-start gap-3'>
            <div
              class='w-9 h-9 rounded-lg bg-iaas-blue/10 flex items-center justify-center shrink-0 mt-0.5'
            >
              <svg
                class='w-4 h-4 text-iaas-blue'
                fill='none'
                viewBox='0 0 24 24'
                stroke='currentColor'
                stroke-width='2'
              >
                <path
                  stroke-linecap='round'
                  stroke-linejoin='round'
                  d='M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z'
                ></path>
              </svg>
            </div>
            <div>
              <h3 class='text-sm font-bold text-gray-900'>
                Estudios Definitivos
              </h3>
              <p
                class='text-[10px] font-semibold text-iaas-gray tracking-wider uppercase'
              >
                Básica y de Detalle
              </p>
            </div>
          </div>

          <!-- Presupuestos y Metrados -->
          <div class='flex items-start gap-3'>
            <div
              class='w-9 h-9 rounded-lg bg-iaas-blue/10 flex items-center justify-center shrink-0 mt-0.5'
            >
              <svg
                class='w-4 h-4 text-iaas-blue'
                fill='none'
                viewBox='0 0 24 24'
                stroke='currentColor'
                stroke-width='2'
              >
                <path
                  stroke-linecap='round'
                  stroke-linejoin='round'
                  d='M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z'
                ></path>
              </svg>
            </div>
            <div>
              <h3 class='text-sm font-bold text-gray-900'>
                Presupuestos y Metrados
              </h3>
              <p
                class='text-[10px] font-semibold text-iaas-gray tracking-wider uppercase'
              >
                Liquidaciones y Costos
              </p>
            </div>
          </div>

          <!-- Estructuras y Arq. -->
          <div class='flex items-start gap-3'>
            <div
              class='w-9 h-9 rounded-lg bg-iaas-blue/10 flex items-center justify-center shrink-0 mt-0.5'
            >
              <svg
                class='w-4 h-4 text-iaas-blue'
                fill='none'
                viewBox='0 0 24 24'
                stroke='currentColor'
                stroke-width='2'
              >
                <path
                  stroke-linecap='round'
                  stroke-linejoin='round'
                  d='M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4'
                ></path>
              </svg>
            </div>
            <div>
              <h3 class='text-sm font-bold text-gray-900'>
                Estructuras y Arq.
              </h3>
              <p
                class='text-[10px] font-semibold text-iaas-gray tracking-wider uppercase'
              >
                Diseño Especializado
              </p>
            </div>
          </div>

          <!-- Peritajes y Tasaciones -->
          <div class='flex items-start gap-3'>
            <div
              class='w-9 h-9 rounded-lg bg-iaas-blue/10 flex items-center justify-center shrink-0 mt-0.5'
            >
              <svg
                class='w-4 h-4 text-iaas-blue'
                fill='none'
                viewBox='0 0 24 24'
                stroke='currentColor'
                stroke-width='2'
              >
                <path
                  stroke-linecap='round'
                  stroke-linejoin='round'
                  d='M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z'></path>
              </svg>
            </div>
            <div>
              <h3 class='text-sm font-bold text-gray-900'>
                Peritajes y Tasaciones
              </h3>
              <p
                class='text-[10px] font-semibold text-iaas-gray tracking-wider uppercase'
              >
                Valoraciones Técnicas
              </p>
            </div>
          </div>
        </div>

        <!-- Discipline Labels -->
        <div class='flex flex-wrap items-end gap-6 sm:gap-8'>
          <div>
            <span
              class='text-xl sm:text-2xl font-extrabold text-iaas-dark tracking-tight'
              >MEP</span
            >
            <p
              class='text-[9px] font-semibold text-iaas-gray tracking-wider uppercase'
            >
              Mecánica/Eléctrica
            </p>
          </div>
          <div>
            <span
              class='text-xl sm:text-2xl font-extrabold text-iaas-dark tracking-tight'
              >SANIT.</span
            >
            <p
              class='text-[9px] font-semibold text-iaas-gray tracking-wider uppercase'
            >
              Instalaciones
            </p>
          </div>
          <div>
            <span
              class='text-xl sm:text-2xl font-extrabold text-iaas-dark tracking-tight'
              >GEOT.</span
            >
            <p
              class='text-[9px] font-semibold text-iaas-gray tracking-wider uppercase'
            >
              Geotecnia
            </p>
          </div>
        </div>
      </div>

      <!-- Right Column: Image + Compromiso Box -->
      <div class='relative rounded-2xl overflow-hidden shadow-lg'>
        <div class='aspect-4/3'>
          <Picture
            src={engineeringBuilding}
            formats={['avif', 'webp']}
            alt='Edificación moderna diseñada con expediente técnico integral'
            class='w-full h-full object-cover'
            widths={[400, 800, 1200]}
            sizes='(max-width: 1024px) 100vw, 50vw'
          />
        </div>
        <!-- Overlay -->
        <div
          class='absolute inset-0 bg-linear-to-t from-iaas-dark/30 to-transparent'
        >
        </div>

        <!-- Compromiso Normativo Box -->
        <div
          class='absolute bottom-0 left-0 right-0 sm:left-auto sm:right-0 sm:w-72 bg-iaas-blue p-5 sm:p-6 sm:rounded-tl-xl'
        >
          <h4 class='text-sm font-bold text-white mb-2'>
            Compromiso Normativo
          </h4>
          <p class='text-[11px] text-white/80 leading-relaxed'>
            Nuestros expedientes cumplen con los más altos estándares nacionales
            e internacionales de construcción y seguridad.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
