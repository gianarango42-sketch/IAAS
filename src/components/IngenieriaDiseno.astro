---
import { Picture } from 'astro:assets';
import engineeringBuilding from '../assets/Edificio_moderno_terminado_202603190949.png';
---

<!-- SECTION: INGENIERÍA, DISEÑO Y EXPEDIENTES TÉCNICOS -->
<section id='ingenieria' class='relative bg-iaas-bg overflow-hidden'>
  <!-- Isometric grid pattern -->
  <div class='absolute inset-0 opacity-[0.03]' style="background-image: linear-gradient(30deg, rgba(10,77,140,1) 1px, transparent 1px), linear-gradient(150deg, rgba(10,77,140,1) 1px, transparent 1px); background-size: 30px 52px;"></div>

  <div class='relative max-w-7xl mx-auto px-6 sm:px-8 lg:px-12 py-14 sm:py-20 lg:py-24'>
    <!-- Header -->
    <div class='mb-10 sm:mb-14 reveal'>
      <div class='inline-flex items-center gap-2 mb-4'>
        <div class='w-8 h-px bg-iaas-blue'></div>
        <span class='text-[11px] font-bold text-iaas-blue tracking-[0.2em] uppercase'>Consultoría</span>
      </div>
      <h2 class='text-2xl sm:text-3xl lg:text-4xl font-bold leading-tight text-gray-900 mb-3'>
        Ingeniería, Diseño y <span class='text-iaas-blue'>Expedientes Técnicos</span>
      </h2>
      <p class='text-sm sm:text-base text-iaas-gray leading-relaxed max-w-xl'>
        Transformamos ideas en proyectos ejecutables con precisión técnica.
      </p>
    </div>

    <!-- Image + Overlapping numbered cards -->
    <div class='relative reveal'>
      <!-- Full width image -->
      <div class='relative rounded-2xl overflow-hidden shadow-xl lg:mr-48'>
        <div class='aspect-21/9 sm:aspect-2/1'>
          <Picture
            src={engineeringBuilding}
            formats={['avif', 'webp']}
            alt='Edificación moderna diseñada con expediente técnico integral'
            class='w-full h-full object-cover'
            widths={[600, 1200, 1800]}
            sizes='(max-width: 768px) 100vw, 1200px'
            quality={80}
            loading='lazy'
          />
        </div>
        <div class='absolute inset-0 bg-gradient-to-r from-iaas-dark/50 via-iaas-dark/20 to-transparent'></div>
      </div>

      <!-- Service cards - overlapping right side on desktop -->
      <div class='relative lg:absolute lg:right-0 lg:top-1/2 lg:-translate-y-1/2 lg:w-96 mt-6 lg:mt-0'>
        <div class='grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-1 gap-3'>
          <!-- Card 1 -->
          <div class='group flex items-start gap-4 bg-white rounded-xl p-4 sm:p-5 shadow-lg hover:shadow-xl transition-all hover:-translate-y-0.5 border border-gray-100'>
            <span class='text-2xl font-black text-iaas-blue/15 leading-none shrink-0 group-hover:text-iaas-blue/30 transition-colors'>01</span>
            <div>
              <h3 class='text-sm font-bold text-gray-900'>Expedientes Técnicos</h3>
              <p class='text-[11px] text-iaas-gray mt-0.5'>Elaboración de expedientes técnicos y estudios definitivos.</p>
            </div>
          </div>

          <!-- Card 2 -->
          <div class='group flex items-start gap-4 bg-white rounded-xl p-4 sm:p-5 shadow-lg hover:shadow-xl transition-all hover:-translate-y-0.5 border border-gray-100'>
            <span class='text-2xl font-black text-iaas-blue/15 leading-none shrink-0 group-hover:text-iaas-blue/30 transition-colors'>02</span>
            <div>
              <h3 class='text-sm font-bold text-gray-900'>Ingeniería de Detalle</h3>
              <p class='text-[11px] text-iaas-gray mt-0.5'>Especialidades: estructural, eléctrica, mecánica y sanitaria.</p>
            </div>
          </div>

          <!-- Card 3 -->
          <div class='group flex items-start gap-4 bg-white rounded-xl p-4 sm:p-5 shadow-lg hover:shadow-xl transition-all hover:-translate-y-0.5 border border-gray-100'>
            <span class='text-2xl font-black text-iaas-blue/15 leading-none shrink-0 group-hover:text-iaas-blue/30 transition-colors'>03</span>
            <div>
              <h3 class='text-sm font-bold text-gray-900'>Ingeniería de Campo</h3>
              <p class='text-[11px] text-iaas-gray mt-0.5'>Elaboración de ingeniería de campo durante la construcción.</p>
            </div>
          </div>

          <!-- Card 4 -->
          <div class='group flex items-start gap-4 bg-white rounded-xl p-4 sm:p-5 shadow-lg hover:shadow-xl transition-all hover:-translate-y-0.5 border border-gray-100'>
            <span class='text-2xl font-black text-iaas-blue/15 leading-none shrink-0 group-hover:text-iaas-blue/30 transition-colors'>04</span>
            <div>
              <h3 class='text-sm font-bold text-gray-900'>Peritajes y Tasaciones</h3>
              <p class='text-[11px] text-iaas-gray mt-0.5'>Servicios de peritajes, tasaciones, metrados y presupuestos.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
