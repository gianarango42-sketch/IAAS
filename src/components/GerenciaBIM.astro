---
import { Image } from 'astro:assets';
import bimStructure from '../assets/Estructura_metalica_acero_vista_202603190948.png';
---

<!-- SECTION 3: GERENCIA DE PROYECTOS Y METODOLOGÍAS BIM -->
<section id='bim' class='relative bg-white overflow-hidden'>
  <div class='max-w-7xl mx-auto px-6 sm:px-8 lg:px-12 py-12 sm:py-16 lg:py-20'>
    <!-- Header -->
    <div class='flex items-start justify-between mb-8 sm:mb-10'>
      <div class='max-w-xl'>
        <h2
          class='text-2xl sm:text-3xl lg:text-4xl font-bold leading-tight text-gray-900 mb-3'
        >
          Gerencia de Proyectos y
          <span class='text-iaas-blue'>Metodologías BIM</span>
        </h2>
        <p class='text-sm text-iaas-gray leading-relaxed'>
          Optimizamos planificación, costos y ejecución mediante herramientas
          digitales de vanguardia.
        </p>
      </div>
    </div>

    <!-- Content Grid: 3 columns on desktop -->
    <div class='grid grid-cols-1 lg:grid-cols-3 gap-6 lg:gap-8 mb-10'>
      <!-- Left Column: Methodologies -->
      <div class='flex flex-col gap-4'>
        <!-- BIM & VDC -->
        <div
          class='bg-white rounded-xl p-5 shadow-sm hover:shadow-md transition-shadow'
        >
          <div class='flex items-center gap-3 mb-2'>
            <div
              class='w-8 h-8 rounded-lg bg-iaas-light flex items-center justify-center shrink-0'
            >
              <svg
                class='w-4 h-4 text-iaas-blue'
                fill='none'
                viewBox='0 0 24 24'
                stroke='currentColor'
                stroke-width='2'
              >
                <path
                  stroke-linecap='round'
                  stroke-linejoin='round'
                  d='M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4'
                ></path>
              </svg>
            </div>
            <h3 class='text-sm font-bold text-gray-900'>BIM & VDC</h3>
          </div>
          <p class='text-[11px] text-iaas-gray leading-relaxed pl-11'>
            Modelado de información para la construcción y diseño virtual
            integrado.
          </p>
        </div>

        <!-- Estándares PMI -->
        <div
          class='bg-white rounded-xl p-5 shadow-sm hover:shadow-md transition-shadow'
        >
          <div class='flex items-center gap-3 mb-2'>
            <div
              class='w-8 h-8 rounded-lg bg-iaas-light flex items-center justify-center shrink-0'
            >
              <svg
                class='w-4 h-4 text-iaas-blue'
                fill='none'
                viewBox='0 0 24 24'
                stroke='currentColor'
                stroke-width='2'
              >
                <path
                  stroke-linecap='round'
                  stroke-linejoin='round'
                  d='M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z'
                ></path>
              </svg>
            </div>
            <h3 class='text-sm font-bold text-gray-900'>Estándares PMI</h3>
          </div>
          <p class='text-[11px] text-iaas-gray leading-relaxed pl-11'>
            Gestión bajo lineamientos del Project Management Institute (PMBOK).
          </p>
        </div>

        <!-- Lean Construction -->
        <div
          class='bg-white rounded-xl p-5 shadow-sm hover:shadow-md transition-shadow'
        >
          <div class='flex items-center gap-3 mb-2'>
            <div
              class='w-8 h-8 rounded-lg bg-iaas-light flex items-center justify-center shrink-0'
            >
              <svg
                class='w-4 h-4 text-iaas-blue'
                fill='none'
                viewBox='0 0 24 24'
                stroke='currentColor'
                stroke-width='2'
              >
                <path
                  stroke-linecap='round'
                  stroke-linejoin='round'
                  d='M13 7h8m0 0v8m0-8l-8 8-4-4-6 6'></path>
              </svg>
            </div>
            <h3 class='text-sm font-bold text-gray-900'>Lean Construction</h3>
          </div>
          <p class='text-[11px] text-iaas-gray leading-relaxed pl-11'>
            Metodología enfocada en eliminar desperdicios y optimizar flujos de
            trabajo.
          </p>
        </div>
      </div>

      <!-- Center: Image -->
      <div
        class='relative rounded-2xl overflow-hidden shadow-lg min-h-62.5 sm:min-h-75'
      >
        <Image
          src={bimStructure}
          alt='Estructura metálica de proyecto gestionado con metodología BIM'
          class='absolute inset-0 w-full h-full object-cover'
          widths={[400, 800]}
          sizes='(max-width: 1024px) 100vw, 33vw'
        />
        <div
          class='absolute inset-0 bg-linear-to-t from-iaas-dark/30 to-transparent'
        >
        </div>
      </div>

      <!-- Right Column: Services -->
      <div class='flex flex-col gap-4'>
        <!-- Control de Costos -->
        <div
          class='bg-white rounded-xl p-5 shadow-sm hover:shadow-md transition-shadow'
        >
          <div class='flex items-center gap-3 mb-2'>
            <div
              class='w-8 h-8 rounded-lg bg-iaas-light flex items-center justify-center shrink-0'
            >
              <svg
                class='w-4 h-4 text-iaas-blue'
                fill='none'
                viewBox='0 0 24 24'
                stroke='currentColor'
                stroke-width='2'
              >
                <path
                  stroke-linecap='round'
                  stroke-linejoin='round'
                  d='M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z'
                ></path>
              </svg>
            </div>
            <div>
              <h3 class='text-sm font-bold text-gray-900'>Control de Costos</h3>
              <p class='text-[11px] text-iaas-gray'>(Cost Engineering)</p>
            </div>
          </div>
          <p class='text-[11px] text-iaas-gray leading-relaxed pl-11'>
            Seguimiento y control presupuestal con análisis de valor ganado.
          </p>
        </div>

        <!-- Planeamiento y Programación -->
        <div
          class='bg-white rounded-xl p-5 shadow-sm hover:shadow-md transition-shadow'
        >
          <div class='flex items-center gap-3 mb-2'>
            <div
              class='w-8 h-8 rounded-lg bg-iaas-light flex items-center justify-center shrink-0'
            >
              <svg
                class='w-4 h-4 text-iaas-blue'
                fill='none'
                viewBox='0 0 24 24'
                stroke='currentColor'
                stroke-width='2'
              >
                <path
                  stroke-linecap='round'
                  stroke-linejoin='round'
                  d='M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z'
                ></path>
              </svg>
            </div>
            <h3 class='text-sm font-bold text-gray-900'>
              Planeamiento y Programación
            </h3>
          </div>
          <p class='text-[11px] text-iaas-gray leading-relaxed pl-11'>
            Cronogramas, rutas críticas y programación de recursos con Last
            Planner.
          </p>
        </div>

        <!-- Metrados y Ratios Físicos -->
        <div
          class='bg-white rounded-xl p-5 shadow-sm hover:shadow-md transition-shadow'
        >
          <div class='flex items-center gap-3 mb-2'>
            <div
              class='w-8 h-8 rounded-lg bg-iaas-light flex items-center justify-center shrink-0'
            >
              <svg
                class='w-4 h-4 text-iaas-blue'
                fill='none'
                viewBox='0 0 24 24'
                stroke='currentColor'
                stroke-width='2'
              >
                <path
                  stroke-linecap='round'
                  stroke-linejoin='round'
                  d='M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z'
                ></path>
              </svg>
            </div>
            <h3 class='text-sm font-bold text-gray-900'>
              Metrados y Ratios Físicos
            </h3>
          </div>
          <p class='text-[11px] text-iaas-gray leading-relaxed pl-11'>
            Cuantificación precisa de partidas y análisis de rendimientos en
            campo.
          </p>
        </div>
      </div>
    </div>

    <!-- Bottom: Cycle Tabs + Áreas de Control Crítico -->
    <div
      class='flex flex-col sm:flex-row items-start sm:items-center justify-between gap-6'
    >
      <!-- Ciclo de Gestión: 3 fases -->
      <div class='flex flex-wrap items-center gap-3'>
        <span
          class='px-5 py-2.5 text-xs font-bold text-white bg-iaas-blue rounded cursor-pointer'
          >PRE INVERSIÓN</span
        >
        <span
          class='px-5 py-2.5 text-xs font-bold text-iaas-blue bg-white border border-iaas-blue/20 rounded hover:bg-iaas-blue hover:text-white transition-colors cursor-pointer'
          >INVERSIÓN</span
        >
        <span
          class='px-5 py-2.5 text-xs font-bold text-iaas-blue bg-white border border-iaas-blue/20 rounded hover:bg-iaas-blue hover:text-white transition-colors cursor-pointer'
          >POST INVERSIÓN</span
        >
      </div>

      <!-- Áreas de Control Crítico -->
      <div
        class='flex flex-wrap items-center gap-x-4 gap-y-1 text-[11px] text-iaas-gray'
      >
        <span class='font-semibold text-gray-900 text-xs'
          >Áreas de Control Crítico:</span
        >
        <span>Alcance</span>
        <span class='text-iaas-blue'>|</span>
        <span>Tiempo</span>
        <span class='text-iaas-blue'>|</span>
        <span>Costo</span>
        <span class='text-iaas-blue'>|</span>
        <span>Calidad</span>
        <span class='text-iaas-blue'>|</span>
        <span>Riesgos</span>
      </div>
    </div>
  </div>
</section>
