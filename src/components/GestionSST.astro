---
import { Image } from 'astro:assets';
import ppeWorker from '../assets/safety-worker-personal-protective-equipment.jpg';
---

<!-- SECTION 4: GESTIÓN SST Y CUMPLIMIENTO NORMATIVO -->
<section id='sst' class='relative bg-iaas-bg overflow-hidden'>
  <div class='max-w-7xl mx-auto px-6 sm:px-8 lg:px-12 py-10 sm:py-14 lg:py-16'>
    <!-- Main Grid -->
    <div class='grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16'>
      <!-- Left Column: Content -->
      <div>
        <!-- Title -->
        <h2
          class='text-3xl sm:text-4xl lg:text-[2.8rem] font-bold leading-tight text-gray-900 mb-4'
        >
          Gestión <span class='text-iaas-blue'>SST</span> y Cumplimiento
          <span class='text-iaas-blue'>Normativo</span>
        </h2>

        <!-- Subtitle -->
        <div class='bg-white border-l-4 border-iaas-blue rounded-r-lg p-4 mb-8'>
          <p class='text-sm text-gray-700 leading-relaxed'>
            Implementación integral bajo la <strong class='text-gray-900'
              >Ley N° 29783</strong
            > para garantizar entornos laborales seguros y productivos.
          </p>
        </div>

        <!-- Two columns: Sistemas de Gestión + Vigilancia Médica -->
        <div class='grid grid-cols-1 sm:grid-cols-2 gap-8 mb-8'>
          <!-- Sistemas de Gestión -->
          <div>
            <div class='flex items-center gap-2.5 mb-4'>
              <div
                class='w-8 h-8 rounded-full bg-iaas-blue flex items-center justify-center'
              >
                <svg
                  class='w-4 h-4 text-white'
                  fill='none'
                  viewBox='0 0 24 24'
                  stroke='currentColor'
                  stroke-width='2'
                >
                  <path
                    stroke-linecap='round'
                    stroke-linejoin='round'
                    d='M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z'
                  ></path>
                </svg>
              </div>
              <h3 class='text-sm font-bold text-gray-900'>
                Sistemas de Gestión
              </h3>
            </div>
            <ul class='space-y-2.5 text-[12px] text-iaas-gray'>
              <li class='flex items-start gap-2'>
                <span class='w-1 h-1 rounded-full bg-iaas-blue mt-1.5 shrink-0'
                ></span>
                Elaboración de IPERC y Matrices
              </li>
              <li class='flex items-start gap-2'>
                <span class='w-1 h-1 rounded-full bg-iaas-blue mt-1.5 shrink-0'
                ></span>
                Reglamentos Internos (RISST)
              </li>
              <li class='flex items-start gap-2'>
                <span class='w-1 h-1 rounded-full bg-iaas-blue mt-1.5 shrink-0'
                ></span>
                Planes de Emergencia y Contingencia
              </li>
              <li class='flex items-start gap-2'>
                <span class='w-1 h-1 rounded-full bg-iaas-blue mt-1.5 shrink-0'
                ></span>
                Auditorías e Inspecciones en campo
              </li>
            </ul>
          </div>

          <!-- Vigilancia Médica -->
          <div>
            <div class='flex items-center gap-2.5 mb-4'>
              <div
                class='w-8 h-8 rounded-full bg-iaas-blue flex items-center justify-center'
              >
                <svg
                  class='w-4 h-4 text-white'
                  fill='none'
                  viewBox='0 0 24 24'
                  stroke='currentColor'
                  stroke-width='2'
                >
                  <path
                    stroke-linecap='round'
                    stroke-linejoin='round'
                    d='M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z'
                  ></path>
                </svg>
              </div>
              <h3 class='text-sm font-bold text-gray-900'>Vigilancia Médica</h3>
            </div>
            <ul class='space-y-2.5 text-[12px] text-iaas-gray'>
              <li class='flex items-start gap-2'>
                <span class='w-1 h-1 rounded-full bg-iaas-blue mt-1.5 shrink-0'
                ></span>
                Capacitación y Entrenamiento
              </li>
              <li class='flex items-start gap-2'>
                <span class='w-1 h-1 rounded-full bg-iaas-blue mt-1.5 shrink-0'
                ></span>
                Higiene y Línea de Base
              </li>
              <li class='flex items-start gap-2'>
                <span class='w-1 h-1 rounded-full bg-iaas-blue mt-1.5 shrink-0'
                ></span>
                Vigilancia Médica Ocupacional
              </li>
              <li class='flex items-start gap-2'>
                <span class='w-1 h-1 rounded-full bg-iaas-blue mt-1.5 shrink-0'
                ></span>
                Exámenes Médicos (vía terceros)
              </li>
            </ul>
          </div>
        </div>

        <!-- Monitoreos Ocupacionales -->
        <div class='bg-iaas-dark rounded-xl p-5 sm:p-6'>
          <h4
            class='text-xs font-bold text-white tracking-wider uppercase mb-4'
          >
            Monitoreos Ocupacionales
          </h4>
          <div class='flex flex-wrap gap-2.5'>
            <span
              class='inline-flex items-center gap-1.5 px-3 py-1.5 bg-white/10 rounded-full text-[11px] text-white/90'
            >
              <svg
                class='w-3 h-3'
                fill='none'
                viewBox='0 0 24 24'
                stroke='currentColor'
                stroke-width='2'
                ><path
                  stroke-linecap='round'
                  stroke-linejoin='round'
                  d='M15.536 8.464a5 5 0 010 7.072M12 6a7.975 7.975 0 015.657 2.343M12 6a7.975 7.975 0 00-5.657 2.343m11.314 0A7.975 7.975 0 0120 12m-8-6a7.975 7.975 0 00-5.657 2.343M4 12a7.975 7.975 0 002.343 5.657'
                ></path></svg
              >
              Ruido
            </span>
            <span
              class='inline-flex items-center gap-1.5 px-3 py-1.5 bg-white/10 rounded-full text-[11px] text-white/90'
            >
              <svg
                class='w-3 h-3'
                fill='none'
                viewBox='0 0 24 24'
                stroke='currentColor'
                stroke-width='2'
                ><path
                  stroke-linecap='round'
                  stroke-linejoin='round'
                  d='M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z'
                ></path></svg
              >
              Iluminación
            </span>
            <span
              class='inline-flex items-center gap-1.5 px-3 py-1.5 bg-white/10 rounded-full text-[11px] text-white/90'
            >
              <svg
                class='w-3 h-3'
                fill='none'
                viewBox='0 0 24 24'
                stroke='currentColor'
                stroke-width='2'
                ><path
                  stroke-linecap='round'
                  stroke-linejoin='round'
                  d='M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707'
                ></path></svg
              >
              Estrés Térmico
            </span>
            <span
              class='inline-flex items-center gap-1.5 px-3 py-1.5 bg-white/10 rounded-full text-[11px] text-white/90'
            >
              <svg
                class='w-3 h-3'
                fill='none'
                viewBox='0 0 24 24'
                stroke='currentColor'
                stroke-width='2'
                ><path
                  stroke-linecap='round'
                  stroke-linejoin='round'
                  d='M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z'
                ></path></svg
              >
              Calidad de Aire
            </span>
            <span
              class='inline-flex items-center gap-1.5 px-3 py-1.5 bg-white/10 rounded-full text-[11px] text-white/90'
            >
              <svg
                class='w-3 h-3'
                fill='none'
                viewBox='0 0 24 24'
                stroke='currentColor'
                stroke-width='2'
                ><path
                  stroke-linecap='round'
                  stroke-linejoin='round'
                  d='M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z'
                ></path></svg
              >
              Agentes Químicos
            </span>
            <span
              class='inline-flex items-center gap-1.5 px-3 py-1.5 bg-white/10 rounded-full text-[11px] text-white/90'
            >
              <svg
                class='w-3 h-3'
                fill='none'
                viewBox='0 0 24 24'
                stroke='currentColor'
                stroke-width='2'
                ><path
                  stroke-linecap='round'
                  stroke-linejoin='round'
                  d='M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z'
                ></path></svg
              >
              Ergonómicos
            </span>
          </div>
        </div>
      </div>

      <!-- Right Column: EPP Illustration + Culture -->
      <div class='flex flex-col items-center justify-center gap-8'>
        <!-- EPP Illustration Area -->
        <div class='relative w-full max-w-sm'>
          <!-- Central worker image -->
          <div class='relative mx-auto w-48 h-64 sm:w-56 sm:h-72'>
            <Image
              src={ppeWorker}
              alt='Trabajador con Equipo de Protección Personal completo'
              class='w-full h-full object-contain'
              width={300}
              height={400}
            />
          </div>

          <!-- EPP Icons surrounding the worker -->
          <div class='absolute top-0 right-0 flex flex-col items-center gap-1'>
            <div
              class='w-14 h-14 rounded-full bg-iaas-light border-2 border-iaas-blue/20 flex items-center justify-center'
            >
              <svg
                class='w-6 h-6 text-iaas-blue'
                fill='none'
                viewBox='0 0 24 24'
                stroke='currentColor'
                stroke-width='1.5'
              >
                <path
                  stroke-linecap='round'
                  stroke-linejoin='round'
                  d='M20.618 5.984A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z'
                ></path>
              </svg>
            </div>
            <span
              class='text-[9px] font-semibold text-iaas-gray text-center uppercase'
              >Protective<br />Helmet</span
            >
          </div>

          <div class='absolute top-8 left-0 flex flex-col items-center gap-1'>
            <div
              class='w-14 h-14 rounded-full bg-iaas-light border-2 border-iaas-blue/20 flex items-center justify-center'
            >
              <svg
                class='w-6 h-6 text-iaas-blue'
                fill='none'
                viewBox='0 0 24 24'
                stroke='currentColor'
                stroke-width='1.5'
              >
                <path
                  stroke-linecap='round'
                  stroke-linejoin='round'
                  d='M15 12a3 3 0 11-6 0 3 3 0 016 0z'></path>
                <path
                  stroke-linecap='round'
                  stroke-linejoin='round'
                  d='M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z'
                ></path>
              </svg>
            </div>
            <span
              class='text-[9px] font-semibold text-iaas-gray text-center uppercase'
              >Eye Wear</span
            >
          </div>

          <div class='absolute top-24 right-0 flex flex-col items-center gap-1'>
            <div
              class='w-14 h-14 rounded-full bg-iaas-light border-2 border-iaas-blue/20 flex items-center justify-center'
            >
              <svg
                class='w-6 h-6 text-iaas-blue'
                fill='none'
                viewBox='0 0 24 24'
                stroke='currentColor'
                stroke-width='1.5'
              >
                <path
                  stroke-linecap='round'
                  stroke-linejoin='round'
                  d='M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z'
                ></path>
              </svg>
            </div>
            <span
              class='text-[9px] font-semibold text-iaas-gray text-center uppercase'
              >Ear Plugs</span
            >
          </div>

          <div
            class='absolute bottom-8 left-0 flex flex-col items-center gap-1'
          >
            <div
              class='w-14 h-14 rounded-full bg-iaas-light border-2 border-iaas-blue/20 flex items-center justify-center'
            >
              <svg
                class='w-6 h-6 text-iaas-blue'
                fill='none'
                viewBox='0 0 24 24'
                stroke='currentColor'
                stroke-width='1.5'
              >
                <path
                  stroke-linecap='round'
                  stroke-linejoin='round'
                  d='M7 11.5V14m0-2.5v-6a1.5 1.5 0 113 0m-3 6a1.5 1.5 0 00-3 0v2a7.5 7.5 0 0015 0v-5a1.5 1.5 0 00-3 0m-6-3V11m0-5.5v-1a1.5 1.5 0 013 0v1m0 0V11m0-5.5a1.5 1.5 0 013 0v3m0 0V11'
                ></path>
              </svg>
            </div>
            <span
              class='text-[9px] font-semibold text-iaas-gray text-center uppercase'
              >Safety<br />Gloves</span
            >
          </div>

          <div
            class='absolute bottom-4 right-0 flex flex-col items-center gap-1'
          >
            <div
              class='w-14 h-14 rounded-full bg-iaas-light border-2 border-iaas-blue/20 flex items-center justify-center'
            >
              <svg
                class='w-6 h-6 text-iaas-blue'
                fill='none'
                viewBox='0 0 24 24'
                stroke='currentColor'
                stroke-width='1.5'
              >
                <path
                  stroke-linecap='round'
                  stroke-linejoin='round'
                  d='M13 10V3L4 14h7v7l9-11h-7z'></path>
              </svg>
            </div>
            <span
              class='text-[9px] font-semibold text-iaas-gray text-center uppercase'
              >High<br />Visibility</span
            >
          </div>
        </div>

        <!-- Cultura de Prevención -->
        <div class='w-full bg-white rounded-xl p-5 sm:p-6 text-center'>
          <h4
            class='text-xs font-bold text-iaas-blue tracking-wider uppercase mb-3'
          >
            Cultura de Prevención
          </h4>
          <blockquote>
            <p class='text-sm text-iaas-gray italic leading-relaxed'>
              "La seguridad no es un gasto, es la inversión más valiosa de su
              organización."
            </p>
          </blockquote>
        </div>
      </div>
    </div>
  </div>
</section>
