---
import { Picture } from 'astro:assets';
import ppeWorker from '../assets/Trabajador_con_EPP_202603190949.png';
---

<!-- SECTION 4: GESTIÓN SST Y CUMPLIMIENTO NORMATIVO -->
<section id='sst' class='relative bg-iaas-bg overflow-hidden'>
  <div class='max-w-7xl mx-auto px-6 sm:px-8 lg:px-12 py-10 sm:py-14 lg:py-16'>
    <!-- Main Grid -->
    <div class='grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16'>
      <!-- Left Column: Content -->
      <div>
        <!-- Title -->
        <h2
          class='text-3xl sm:text-4xl lg:text-[2.8rem] font-bold leading-tight text-gray-900 mb-4'
        >
          Gestión <span class='text-iaas-blue'>SST</span> y Cumplimiento
          <span class='text-iaas-blue'>Normativo</span>
        </h2>

        <!-- Subtitle -->
        <div class='bg-white border-l-4 border-iaas-blue rounded-r-lg p-4 mb-8'>
          <p class='text-sm text-gray-700 leading-relaxed'>
            Garantizamos entornos laborales seguros y cumplimiento legal bajo la <strong class='text-gray-900'>Ley N° 29783</strong>, y las diferentes normativas sectoriales así como estándares ISO.
          </p>
        </div>

        <!-- ISO 45001 -->
        <div class='mb-8'>
          <div class='flex items-center gap-2.5 mb-4'>
            <div
              class='w-8 h-8 rounded-full bg-iaas-blue flex items-center justify-center'
            >
              <svg
                class='w-4 h-4 text-white'
                fill='none'
                viewBox='0 0 24 24'
                stroke='currentColor'
                stroke-width='2'
              >
                <path
                  stroke-linecap='round'
                  stroke-linejoin='round'
                  d='M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z'
                ></path>
              </svg>
            </div>
            <h3 class='text-sm font-bold text-gray-900'>
              Implementación de Sistemas de Gestión ISO 45001
            </h3>
          </div>
          <div class='grid grid-cols-1 sm:grid-cols-2 gap-2.5 pl-10'>
            <div class='flex items-start gap-2 text-[12px] text-iaas-gray'>
              <span class='w-1 h-1 rounded-full bg-iaas-blue mt-1.5 shrink-0'></span>
              Consultoría para Certificación ISO 45001
            </div>
            <div class='flex items-start gap-2 text-[12px] text-iaas-gray'>
              <span class='w-1 h-1 rounded-full bg-iaas-blue mt-1.5 shrink-0'></span>
              Homologación de proveedores
            </div>
            <div class='flex items-start gap-2 text-[12px] text-iaas-gray'>
              <span class='w-1 h-1 rounded-full bg-iaas-blue mt-1.5 shrink-0'></span>
              Auditorías
            </div>
            <div class='flex items-start gap-2 text-[12px] text-iaas-gray'>
              <span class='w-1 h-1 rounded-full bg-iaas-blue mt-1.5 shrink-0'></span>
              Supervisión de trabajos de alto riesgo
            </div>
            <div class='flex items-start gap-2 text-[12px] text-iaas-gray'>
              <span class='w-1 h-1 rounded-full bg-iaas-blue mt-1.5 shrink-0'></span>
              Gestión de contratistas
            </div>
            <div class='flex items-start gap-2 text-[12px] text-iaas-gray'>
              <span class='w-1 h-1 rounded-full bg-iaas-blue mt-1.5 shrink-0'></span>
              Asesoría legal SST
            </div>
          </div>
        </div>

        <!-- Capacitación + ITSE + Seguridad en Diseño -->
        <div class='space-y-4'>
          <div class='bg-white rounded-xl p-4 shadow-sm'>
            <h4 class='text-xs font-bold text-gray-900 mb-1.5'>Capacitación Especializada</h4>
            <p class='text-[11px] text-iaas-gray leading-relaxed'>
              Trabajos de alto riesgo en altura, espacios confinados, eléctricos, izaje de cargas, entre otros.
            </p>
          </div>
          <div class='bg-white rounded-xl p-4 shadow-sm'>
            <h4 class='text-xs font-bold text-gray-900 mb-1.5'>Inspecciones Técnicas de Seguridad en Edificaciones (ITSE)</h4>
            <p class='text-[11px] text-iaas-gray leading-relaxed'>
              Evaluación integral de seguridad en edificaciones conforme a la normativa vigente.
            </p>
          </div>
          <div class='bg-white rounded-xl p-4 shadow-sm'>
            <h4 class='text-xs font-bold text-gray-900 mb-1.5'>Seguridad en el Diseño</h4>
            <p class='text-[11px] text-iaas-gray leading-relaxed'>
              Integra medidas de protección desde las etapas iniciales de un proyecto, en lugar de añadirlas posteriormente. Este enfoque proactivo reduce vulnerabilidades.
            </p>
          </div>
        </div>
      </div>

      <!-- Right Column: Image with floating badges -->
      <div class='flex flex-col items-center justify-start gap-6'>
        <div class='relative w-full max-w-md px-6 sm:px-10 py-6 sm:py-8'>
          <!-- Main image -->
          <div class='relative mx-auto w-64 sm:w-72 rounded-2xl overflow-hidden shadow-[0_20px_50px_-18px_rgba(10,77,140,0.35)] border border-white/70'>
            <div class='aspect-3/4 sm:aspect-4/5 bg-white'>
              <Picture
                src={ppeWorker}
                formats={['avif', 'webp']}
                alt='Trabajador con Equipo de Protección Personal completo'
                class='w-full h-full object-cover object-top'
                widths={[320, 480, 768]}
                sizes='(max-width: 640px) 320px, (max-width: 1024px) 480px, 768px'
                quality={80}
                loading='lazy'
              />
            </div>
            <div class='absolute inset-0 bg-linear-to-t from-iaas-dark/35 via-transparent to-transparent'></div>
          </div>

          <!-- Floating badge: ISO 45001 (top-left) -->
          <div class='absolute top-0 left-0 bg-iaas-blue rounded-xl px-3 py-2 shadow-lg'>
            <div class='flex items-center gap-1.5'>
              <svg class='w-3.5 h-3.5 text-white shrink-0' fill='none' viewBox='0 0 24 24' stroke='currentColor' stroke-width='2'>
                <path stroke-linecap='round' stroke-linejoin='round' d='M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z'></path>
              </svg>
              <span class='text-[10px] font-bold text-white'>ISO 45001</span>
            </div>
          </div>

          <!-- Floating badge: Monitoreos (top-right) -->
          <div class='absolute top-0 right-0 bg-white/95 backdrop-blur-sm rounded-xl border border-iaas-blue/15 px-3 py-2 shadow-md'>
            <div class='flex items-center gap-1.5'>
              <svg class='w-3.5 h-3.5 text-iaas-blue shrink-0' fill='none' viewBox='0 0 24 24' stroke='currentColor' stroke-width='2'>
                <path stroke-linecap='round' stroke-linejoin='round' d='M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z'></path>
              </svg>
              <span class='text-[10px] font-semibold text-iaas-gray'>Monitoreos</span>
            </div>
          </div>

          <!-- Floating badge: Capacitación (mid-left) -->
          <div class='absolute top-1/3 -left-2 sm:left-0 bg-white/95 backdrop-blur-sm rounded-xl border border-iaas-blue/15 px-3 py-2 shadow-md'>
            <div class='flex items-center gap-1.5'>
              <svg class='w-3.5 h-3.5 text-iaas-blue shrink-0' fill='none' viewBox='0 0 24 24' stroke='currentColor' stroke-width='2'>
                <path stroke-linecap='round' stroke-linejoin='round' d='M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253'></path>
              </svg>
              <span class='text-[10px] font-semibold text-iaas-gray'>Capacitación</span>
            </div>
          </div>

          <!-- Floating badge: ITSE (mid-right) -->
          <div class='absolute top-2/3 -right-2 sm:right-0 bg-white/95 backdrop-blur-sm rounded-xl border border-iaas-blue/15 px-3 py-2 shadow-md'>
            <div class='flex items-center gap-1.5'>
              <svg class='w-3.5 h-3.5 text-iaas-blue shrink-0' fill='none' viewBox='0 0 24 24' stroke='currentColor' stroke-width='2'>
                <path stroke-linecap='round' stroke-linejoin='round' d='M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4'></path>
              </svg>
              <span class='text-[10px] font-semibold text-iaas-gray'>ITSE</span>
            </div>
          </div>

          <!-- Floating badge: Seguridad en Diseño (bottom-center) -->
          <div class='absolute bottom-0 left-1/2 -translate-x-1/2 bg-white/95 backdrop-blur-sm rounded-xl border border-iaas-blue/15 px-3 py-2 shadow-md'>
            <div class='flex items-center gap-1.5'>
              <svg class='w-3.5 h-3.5 text-iaas-blue shrink-0' fill='none' viewBox='0 0 24 24' stroke='currentColor' stroke-width='2'>
                <path stroke-linecap='round' stroke-linejoin='round' d='M11 4a2 2 0 114 0v1a1 1 0 001 1h3a1 1 0 011 1v3a1 1 0 01-1 1h-1a2 2 0 100 4h1a1 1 0 011 1v3a1 1 0 01-1 1h-3a1 1 0 01-1-1v-1a2 2 0 10-4 0v1a1 1 0 01-1 1H7a1 1 0 01-1-1v-3a1 1 0 00-1-1H4a2 2 0 110-4h1a1 1 0 001-1V7a1 1 0 011-1h3a1 1 0 001-1V4z'></path>
              </svg>
              <span class='text-[10px] font-semibold text-iaas-gray whitespace-nowrap'>Seguridad en Diseño</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Monitoreos Ocupacionales - barra inferior -->
    <div class='mt-10 sm:mt-14'>
      <div class='flex items-center gap-3 mb-4'>
        <div class='w-8 h-8 rounded-full bg-iaas-dark flex items-center justify-center'>
          <svg class='w-4 h-4 text-white' fill='none' viewBox='0 0 24 24' stroke='currentColor' stroke-width='2'>
            <path stroke-linecap='round' stroke-linejoin='round' d='M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z'></path>
          </svg>
        </div>
        <h3 class='text-sm font-bold text-gray-900'>Monitoreos Ocupacionales</h3>
      </div>
      <div class='grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-3'>
        <div class='bg-white rounded-xl p-4 text-center shadow-sm hover:shadow-md transition-shadow'>
          <svg class='w-5 h-5 text-iaas-blue mx-auto mb-2' fill='none' viewBox='0 0 24 24' stroke='currentColor' stroke-width='2'>
            <path stroke-linecap='round' stroke-linejoin='round' d='M15.536 8.464a5 5 0 010 7.072M12 6a7.975 7.975 0 015.657 2.343M12 6a7.975 7.975 0 00-5.657 2.343m11.314 0A7.975 7.975 0 0120 12m-8-6a7.975 7.975 0 00-5.657 2.343M4 12a7.975 7.975 0 002.343 5.657'></path>
          </svg>
          <p class='text-[11px] font-semibold text-gray-900'>Ruido</p>
        </div>
        <div class='bg-white rounded-xl p-4 text-center shadow-sm hover:shadow-md transition-shadow'>
          <svg class='w-5 h-5 text-iaas-blue mx-auto mb-2' fill='none' viewBox='0 0 24 24' stroke='currentColor' stroke-width='2'>
            <path stroke-linecap='round' stroke-linejoin='round' d='M15.536 8.464a5 5 0 010 7.072M12 6a7.975 7.975 0 015.657 2.343M12 6a7.975 7.975 0 00-5.657 2.343m11.314 0A7.975 7.975 0 0120 12m-8-6a7.975 7.975 0 00-5.657 2.343M4 12a7.975 7.975 0 002.343 5.657'></path>
          </svg>
          <p class='text-[11px] font-semibold text-gray-900'>Vibraciones</p>
        </div>
        <div class='bg-white rounded-xl p-4 text-center shadow-sm hover:shadow-md transition-shadow'>
          <svg class='w-5 h-5 text-iaas-blue mx-auto mb-2' fill='none' viewBox='0 0 24 24' stroke='currentColor' stroke-width='2'>
            <path stroke-linecap='round' stroke-linejoin='round' d='M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z'></path>
          </svg>
          <p class='text-[11px] font-semibold text-gray-900'>Iluminación</p>
        </div>
        <div class='bg-white rounded-xl p-4 text-center shadow-sm hover:shadow-md transition-shadow'>
          <svg class='w-5 h-5 text-iaas-blue mx-auto mb-2' fill='none' viewBox='0 0 24 24' stroke='currentColor' stroke-width='2'>
            <path stroke-linecap='round' stroke-linejoin='round' d='M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707'></path>
          </svg>
          <p class='text-[11px] font-semibold text-gray-900'>Estrés Térmico</p>
        </div>
        <div class='bg-white rounded-xl p-4 text-center shadow-sm hover:shadow-md transition-shadow col-span-2 sm:col-span-1'>
          <svg class='w-5 h-5 text-iaas-blue mx-auto mb-2' fill='none' viewBox='0 0 24 24' stroke='currentColor' stroke-width='2'>
            <path stroke-linecap='round' stroke-linejoin='round' d='M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z'></path>
          </svg>
          <p class='text-[11px] font-semibold text-gray-900'>Calidad de Aire</p>
        </div>
      </div>
    </div>
  </div>
</section>
