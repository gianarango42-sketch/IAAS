---
import { Picture } from 'astro:assets';
import environmentalMonitoring from '../assets/Tecnico_con_equipo_202603190949.png';
---

<!-- SECTION 5: GESTIÓN Y MONITOREO AMBIENTAL -->
<section id='ambiental' class='relative bg-white overflow-hidden'>
  <div class='max-w-7xl mx-auto px-6 sm:px-8 lg:px-12 py-12 sm:py-16 lg:py-20'>
    <!-- Title -->
    <h2
      class='text-2xl sm:text-3xl lg:text-4xl font-bold leading-tight text-gray-900 mb-4'
    >
      Gestión y <span class='text-iaas-blue'>Monitoreo Ambiental</span>
    </h2>

    <!-- Subtitle -->
    <p class='text-sm text-iaas-gray leading-relaxed max-w-2xl mb-8 sm:mb-10'>
      Promovemos el desarrollo sostenible de sus proyectos mediante una gestión ambiental rigurosa.
    </p>

    <!-- Main Image -->
    <div
      class='relative rounded-2xl overflow-hidden shadow-lg mb-10 aspect-21/9'
    >
      <Picture
        src={environmentalMonitoring}
        formats={['avif', 'webp']}
        alt='Equipo de monitoreo ambiental realizando mediciones en campo'
        class='w-full h-full object-cover'
        widths={[600, 1200, 1800]}
        sizes='(max-width: 768px) 100vw, 1200px'
        quality={80}
        loading='lazy'
      />
      <div
        class='absolute inset-0 bg-linear-to-t from-iaas-dark/20 to-transparent'
      >
      </div>
    </div>

    <!-- 3 Columns of Services -->
    <div
      class='grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8 mb-8'
    >
      <!-- Estudios Ambientales -->
      <div
        class='bg-iaas-bg rounded-xl p-6 shadow-sm hover:shadow-md transition-shadow'
      >
        <div class='flex items-center gap-3 mb-4'>
          <div
            class='w-9 h-9 rounded-lg bg-iaas-light flex items-center justify-center shrink-0'
          >
            <svg
              class='w-4.5 h-4.5 text-iaas-blue'
              fill='none'
              viewBox='0 0 24 24'
              stroke='currentColor'
              stroke-width='2'
            >
              <path
                stroke-linecap='round'
                stroke-linejoin='round'
                d='M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z'
              ></path>
            </svg>
          </div>
          <h3 class='text-sm font-bold text-gray-900'>Sistema de Gestión ISO 14001</h3>
        </div>
        <ul class='space-y-2 text-[12px] text-iaas-gray'>
          <li class='flex items-start gap-2'>
            <span class='w-1 h-1 rounded-full bg-iaas-blue mt-1.5 shrink-0'
            ></span>
            Implementación de sistema de gestión ISO 14001
          </li>
          <li class='flex items-start gap-2'>
            <span class='w-1 h-1 rounded-full bg-iaas-blue mt-1.5 shrink-0'
            ></span>
            Consultoría para Certificación ISO 14001
          </li>
          <li class='flex items-start gap-2'>
            <span class='w-1 h-1 rounded-full bg-iaas-blue mt-1.5 shrink-0'
            ></span>
            Homologación de proveedores y auditorías
          </li>
          <li class='flex items-start gap-2'>
            <span class='w-1 h-1 rounded-full bg-iaas-blue mt-1.5 shrink-0'
            ></span>
            Elaboración de permisos en diferentes sectores industriales
          </li>
        </ul>
      </div>

      <!-- Monitoreo de Calidad -->
      <div
        class='bg-iaas-bg rounded-xl p-6 shadow-sm hover:shadow-md transition-shadow'
      >
        <div class='flex items-center gap-3 mb-4'>
          <div
            class='w-9 h-9 rounded-lg bg-iaas-light flex items-center justify-center shrink-0'
          >
            <svg
              class='w-4.5 h-4.5 text-iaas-blue'
              fill='none'
              viewBox='0 0 24 24'
              stroke='currentColor'
              stroke-width='2'
            >
              <path
                stroke-linecap='round'
                stroke-linejoin='round'
                d='M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z'
              ></path>
            </svg>
          </div>
          <h3 class='text-sm font-bold text-gray-900'>Instrumentos Ambientales</h3>
        </div>
        <ul class='space-y-2 text-[12px] text-iaas-gray'>
          <li class='flex items-start gap-2'>
            <span class='w-1 h-1 rounded-full bg-iaas-blue mt-1.5 shrink-0'
            ></span>
            Elaboración de instrumentos: DIA, EIA, ITS
          </li>
          <li class='flex items-start gap-2'>
            <span class='w-1 h-1 rounded-full bg-iaas-blue mt-1.5 shrink-0'
            ></span>
            Planes de manejo de residuos sólidos
          </li>
          <li class='flex items-start gap-2'>
            <span class='w-1 h-1 rounded-full bg-iaas-blue mt-1.5 shrink-0'
            ></span>
            Planes de cierre y abandono
          </li>
        </ul>
      </div>

      <!-- Residuos y Auditoría -->
      <div
        class='bg-iaas-bg rounded-xl p-6 shadow-sm hover:shadow-md transition-shadow'
      >
        <div class='flex items-center gap-3 mb-4'>
          <div
            class='w-9 h-9 rounded-lg bg-iaas-light flex items-center justify-center shrink-0'
          >
            <svg
              class='w-4.5 h-4.5 text-iaas-blue'
              fill='none'
              viewBox='0 0 24 24'
              stroke='currentColor'
              stroke-width='2'
            >
              <path
                stroke-linecap='round'
                stroke-linejoin='round'
                d='M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15'
              ></path>
            </svg>
          </div>
          <h3 class='text-sm font-bold text-gray-900'>Monitoreos Ambientales</h3>
        </div>
        <ul class='space-y-2 text-[12px] text-iaas-gray'>
          <li class='flex items-start gap-2'>
            <span class='w-1 h-1 rounded-full bg-iaas-blue mt-1.5 shrink-0'
            ></span>
            Calidad de aire
          </li>
          <li class='flex items-start gap-2'>
            <span class='w-1 h-1 rounded-full bg-iaas-blue mt-1.5 shrink-0'
            ></span>
            Agua y suelo
          </li>
          <li class='flex items-start gap-2'>
            <span class='w-1 h-1 rounded-full bg-iaas-blue mt-1.5 shrink-0'
            ></span>
            Emisiones
          </li>
        </ul>
      </div>
    </div>

  </div>
</section>
