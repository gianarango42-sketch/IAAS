---
import logo from '../assets/logo.svg';
---

<!-- FOOTER -->
<footer class='relative bg-iaas-dark overflow-hidden'>
  <!-- Topographic line accent -->
  <div class='absolute inset-0 opacity-[0.03]' style="background-image: linear-gradient(rgba(255,255,255,1) 1px, transparent 1px); background-size: 100% 20px;"></div>
  <div class='absolute top-0 left-0 w-full h-px bg-gradient-to-r from-transparent via-iaas-blue/40 to-transparent'></div>

  <div class='relative max-w-7xl mx-auto px-6 sm:px-8 lg:px-12 py-6 sm:py-8'>
    <div class='flex flex-col sm:flex-row items-center justify-between gap-6'>
      <!-- Logo + tagline -->
      <div class='flex items-center gap-4'>
        <img src={logo.src} alt='IAAS Logo' class='h-10 w-auto brightness-0 invert opacity-80' />
        <div class='hidden sm:block w-px h-8 bg-white/15'></div>
        <span class='hidden sm:block text-[11px] text-white/40 max-w-48 leading-relaxed'>
          Gestión Integral de Proyectos de Construcción
        </span>
      </div>

      <!-- Links -->
      <div class='flex flex-wrap items-center justify-center gap-6 text-[11px] sm:text-xs text-white/60'>
        <a href='mailto:proyectos@iaasperu.com' class='hover:text-white transition-colors flex items-center gap-1.5'>
          <svg class='w-3.5 h-3.5' fill='none' viewBox='0 0 24 24' stroke='currentColor' stroke-width='2'>
            <path stroke-linecap='round' stroke-linejoin='round' d='M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z'></path>
          </svg>
          proyectos@iaasperu.com
        </a>
        <a href='https://www.iaasperu.com' class='hover:text-white transition-colors flex items-center gap-1.5'>
          <svg class='w-3.5 h-3.5' fill='none' viewBox='0 0 24 24' stroke='currentColor' stroke-width='2'>
            <path stroke-linecap='round' stroke-linejoin='round' d='M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9'></path>
          </svg>
          www.iaasperu.com
        </a>
      </div>
    </div>

  </div>
</footer>
